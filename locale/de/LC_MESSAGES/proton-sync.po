msgstr "  ⛔ Remote-Leerung VERWEIGERT (Einbindungsschutz): {r}"

#: proton_sync.py:1060
msgid "     Nothing deleted remotely — this mapping was NOT reset."
msgstr ""
"     Nichts remote gelöscht — diese Zuordnung wurde NICHT zurückgesetzt."

#: proton_sync.py:1065
#, python-brace-format
msgid "  ♻ No remote folder to wipe (already absent): {p}"
msgstr "  ♻ Kein Remote-Ordner zu leeren (bereits nicht vorhanden): {p}"

#: proton_sync.py:1067
#, python-brace-format
msgid "  🗑  Wiping remote folder to TRASH: {p}"
msgstr "  🗑  Remote-Ordner in den PAPIERKORB leeren: {p}"

#: proton_sync.py:1097 proton_sync.py:1114
#, python-brace-format
msgid "  ❌ Could not read {p}: {e}"
msgstr "  ❌ {p} konnte nicht gelesen werden: {e}"

#: proton_sync.py:1175
#, python-brace-format
msgid "  ⚡ {t}, skipping the CLI call for {p}"
msgstr "  ⚡ {t}, CLI-Aufruf für {p} wird übersprungen"


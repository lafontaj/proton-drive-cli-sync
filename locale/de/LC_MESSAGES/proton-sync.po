#, python-brace-format
msgid "    ⚠  Could not create {p}: {e}"
msgstr "    ⚠  {p} konnte nicht erstellt werden: {e}"

#: proton_sync.py:731
#, python-brace-format
msgid "    (nothing found at {p}: {e})"
msgstr "    (nichts gefunden bei {p}: {e})"

#: proton_sync.py:738
msgid "    [debug] first raw element received from 'filesystem list -j':"
msgstr "    [debug] erstes Rohelement von 'filesystem list -j' empfangen:"

#: proton_sync.py:773
#, python-brace-format
msgid "    (remote size unknown for {f}, re-sending to be safe)"
msgstr ""
"    (Remote-Größe für {f} unbekannt, wird zur Sicherheit erneut gesendet)"

#: proton_sync.py:781
#, python-brace-format
msgid "    (same size but different content: {f})"
msgstr "    (gleiche Größe, aber anderer Inhalt: {f})"

#: proton_sync.py:876
#, python-brace-format
msgid "    [DRY-RUN] would upload: {p}"
msgstr "    [DRY-RUN] würde hochladen: {p}"

#: proton_sync.py:898
#, python-brace-format
msgid "    ✅ {n} file(s) sent to {p}"
msgstr "    ✅ {n} Datei(en) an {p} gesendet"

#: proton_sync.py:904
#, python-brace-format
msgid ""
"    ⚠  Batch upload to {p} reported a failure — isolating the culprit "
"file(s)…"
msgstr ""
"    ⚠  Stapel-Upload zu {p} meldete einen Fehler — verursachende Datei(en) "
"werden isoliert…"

#: proton_sync.py:923
#, python-brace-format
msgid "      – vanished before upload (deleted meanwhile), skipped: {p}"
msgstr ""
"      – vor dem Upload verschwunden (zwischenzeitlich gelöscht), "
"übersprungen: {p}"

#: proton_sync.py:934
#, python-brace-format
msgid "      – vanished during upload (deleted meanwhile), skipped: {p}"
msgstr ""
"      – während des Uploads verschwunden (zwischenzeitlich gelöscht), "
"übersprungen: {p}"

#: proton_sync.py:941
#, python-brace-format
msgid "      ⚠ thumbnail/codec issue — retrying without thumbnail: {p}"
msgstr ""
"      ⚠ Miniaturansicht-/Codec-Problem — erneuter Versuch ohne "
"Miniaturansicht: {p}"

#: proton_sync.py:945
#, python-brace-format
msgid "      ✓ uploaded WITHOUT thumbnail (no Proton preview): {p}"
msgstr "      ✓ OHNE Miniaturansicht hochgeladen (keine Proton-Vorschau): {p}"

#: proton_sync.py:954
#, python-brace-format
msgid "      ✓ recovered on individual retry: {p}"
msgstr "      ✓ beim einzelnen erneuten Versuch wiederhergestellt: {p}"

#: proton_sync.py:957
#, python-brace-format
msgid "    ❌ upload failed: {p}"
msgstr "    ❌ Upload fehlgeschlagen: {p}"

#: proton_sync.py:958
#, python-brace-format
msgid "    ❌   reason: {e}"
msgstr "    ❌   Grund: {e}"

#: proton_sync.py:958
msgid "(no message from the CLI)"
msgstr "(keine Meldung von der CLI)"

#: proton_sync.py:962
#, python-brace-format
msgid "    ✅ {n} file(s) recovered on individual retry."
msgstr ""
"    ✅ {n} Datei(en) beim einzelnen erneuten Versuch wiederhergestellt."

#: proton_sync.py:964
#, python-brace-format
msgid ""
"    ⚠  {n} file(s) uploaded WITHOUT thumbnail (image format needs an OS "
"codec — saved anyway, logged in {log})."
msgstr ""
"    ⚠  {n} Datei(en) OHNE Miniaturansicht hochgeladen (Bildformat benötigt "
"einen OS-Codec — trotzdem gespeichert, protokolliert in {log})."

#: proton_sync.py:967
#, python-brace-format
msgid ""
"    – {n} file(s) vanished (deleted meanwhile) — skipped, not a failure."
msgstr ""
"    – {n} Datei(en) verschwunden (zwischenzeitlich gelöscht) — übersprungen, "
"kein Fehler."

#: proton_sync.py:969
#, python-brace-format
msgid "    ❌ {n} file(s) still failing (see the failures log: {log})."
msgstr ""
"    ❌ {n} Datei(en) weiterhin fehlerhaft (siehe Fehlerprotokoll: {log})."

#: proton_sync.py:982
msgid "would delete PERMANENTLY"
msgstr "würde ENDGÜLTIG löschen"

#: proton_sync.py:982
msgid "would move to trash"
msgstr "würde in den Papierkorb verschieben"

#: proton_sync.py:987
#, python-brace-format
msgid "    ❌ {a} of {p} failed: {e}"
msgstr "    ❌ {a} von {p} fehlgeschlagen: {e}"

#: proton_sync.py:989
msgid "permanently deleted"
msgstr "endgültig gelöscht"

#: proton_sync.py:989
msgid "sent to trash"
msgstr "in den Papierkorb verschoben"

#: proton_sync.py:1027
#, python-brace-format
msgid "    (orphan folder: {n} — ~{c} remote element(s))"
msgstr "    (verwaister Ordner: {n} — ~{c} Remote-Element(e))"


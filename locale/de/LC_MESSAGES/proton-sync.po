#, python-brace-format
msgid "  🚫 excluded (folder): {p}"
msgstr "  🚫 ausgeschlossen (Ordner): {p}"

#: proton_sync.py:1214
#, python-brace-format
msgid "    🚫 excluded ({k}): {p}"
msgstr "    🚫 ausgeschlossen ({k}): {p}"

#: proton_sync.py:1230 proton_sync.py:1318
#, python-brace-format
msgid "    ⏭  unchanged: {p}"
msgstr "    ⏭  unverändert: {p}"

#: proton_sync.py:1289
#, python-brace-format
msgid "  ⚠  Deletions disabled for this mapping: {r}"
msgstr "  ⚠  Löschungen für diese Zuordnung deaktiviert: {r}"

#: proton_sync.py:1290 proton_sync.py:1477
msgid "      (uploads continue normally)"
msgstr "      (Uploads laufen normal weiter)"

#: proton_sync.py:1293 proton_sync.py:1480
msgid "permanent"
msgstr "endgültig"

#: proton_sync.py:1293 proton_sync.py:1480
msgid "to trash"
msgstr "in den Papierkorb"

#: proton_sync.py:1294
#, python-brace-format
msgid "  🗑  Deletion propagation ACTIVE ({l}) for this mapping"
msgstr "  🗑  Löschübertragung AKTIV ({l}) für diese Zuordnung"

#: proton_sync.py:1309
#, python-brace-format
msgid "    🚫 excluded (file): {p}"
msgstr "    🚫 ausgeschlossen (Datei): {p}"

#: proton_sync.py:1420
#, python-brace-format
msgid "  ❌ Subpath not found or not a folder: {p}"
msgstr "  ❌ Unterpfad nicht gefunden oder kein Ordner: {p}"

#: proton_sync.py:1433
#, python-brace-format
msgid "subpath excluded (“{s}” filtered), skipped: {p}"
msgstr "Unterpfad ausgeschlossen („{s}“ gefiltert), übersprungen: {p}"

#: proton_sync.py:1455
#, python-brace-format
msgid ""
"folder not fully indexed yet (cache not built by a full pass), deferred to "
"scheduling: {p}"
msgstr ""
"Ordner noch nicht vollständig indexiert (Cache nicht durch einen "
"vollständigen Durchlauf erstellt), auf Zeitplan verschoben: {p}"

#: proton_sync.py:1476
#, python-brace-format
msgid "  ⚠  Deletions disabled for this subpath: {r}"
msgstr "  ⚠  Löschungen für diesen Unterpfad deaktiviert: {r}"

#: proton_sync.py:1481
#, python-brace-format
msgid "  🗑  Deletion propagation ACTIVE ({l}) for this subpath"
msgstr "  🗑  Löschübertragung AKTIV ({l}) für diesen Unterpfad"

#: proton_sync.py:1483
#, python-brace-format
msgid "  ↪ subpath: {s}  =>  {d}"
msgstr "  ↪ Unterpfad: {s}  =>  {d}"

#: proton_sync.py:1617
msgid "❌ --wipe-remote requires --reset-source."
msgstr "❌ --wipe-remote erfordert --reset-source."

#: proton_sync.py:1638 proton_sync.py:1678
#, python-brace-format
msgid "❌ proton-drive binary not found at {p}"
msgstr "❌ proton-drive-Binärdatei nicht gefunden unter {p}"

#: proton_sync.py:1660
msgid "❌ A mappings file is required (config)."
msgstr "❌ Eine Zuordnungsdatei ist erforderlich (Konfiguration)."

#: proton_sync.py:1672
msgid "❌ Another instance of proton_sync.py is already running."
msgstr "❌ Eine andere Instanz von proton_sync.py läuft bereits."

#: proton_sync.py:1673
#, python-brace-format
msgid "   Lock: {p}"
msgstr "   Sperre: {p}"

#: proton_sync.py:1674
msgid "   (If you are sure no other instance is running, delete this file.)"
msgstr ""
"   (Wenn Sie sicher sind, dass keine andere Instanz läuft, löschen Sie diese "
"Datei.)"

#: proton_sync.py:1679
msgid "   Adjust the PROTON_DRIVE_CLI environment variable if needed."
msgstr "   Passen Sie bei Bedarf die Umgebungsvariable PROTON_DRIVE_CLI an."

#: proton_sync.py:1693
msgid "Proton Drive authentication impossible — pass skipped."
msgstr "Proton-Drive-Authentifizierung nicht möglich — Durchlauf übersprungen."

#: proton_sync.py:1694
msgid "   Likely cause: the graphical session is not open, so the"
msgstr ""
"   Wahrscheinliche Ursache: die grafische Sitzung ist nicht geöffnet, daher "
"ist der"

#: proton_sync.py:1695
msgid "   secrets keyring is locked and the CLI cannot read its"
msgstr "   Schlüsselbund gesperrt und die CLI kann ihre"

#: proton_sync.py:1696
msgid "   credentials."
msgstr "   Anmeldedaten nicht lesen."

#: proton_sync.py:1698
#, python-brace-format
msgid "   CLI detail: {e}"
msgstr "   CLI-Detail: {e}"

#: proton_sync.py:1699
msgid "   (This is not a serious error: the next run will retry."
msgstr ""
"   (Dies ist kein schwerwiegender Fehler: der nächste Lauf versucht es "
"erneut."

#: proton_sync.py:1700
msgid "    Open this user's session to unlock the keyring.)"
msgstr ""
"    Öffnen Sie die Sitzung dieses Benutzers, um den Schlüsselbund zu "
"entsperren.)"

#: proton_sync.py:1730
#, python-brace-format
msgid ""
"Account change accepted ({a} → {b}) — the previous cache is discarded and "
"will be rebuilt for the new account."
msgstr ""
"Kontowechsel akzeptiert ({a} → {b}) — der vorherige Cache wird verworfen und "
"für das neue Konto neu aufgebaut."

#: proton_sync.py:1737
#, python-brace-format
msgid ""
"The connected Proton account has changed: this cache was built for {a}, but "
"the session is now {b}."
msgstr ""
"Das verbundene Proton-Konto hat sich geändert: dieser Cache wurde für {a} "
"erstellt, aber die Sitzung ist jetzt {b}."

#: proton_sync.py:1740
msgid ""
"   Nothing was synced or modified — the cache describes the OLD account's "
"Drive."
msgstr ""
"   Nichts wurde synchronisiert oder geändert — der Cache beschreibt das "
"Drive des ALTEN Kontos."

#: proton_sync.py:1742
msgid ""
"   To proceed on the NEW account: run “Prime the cache” (or reset the "
"mappings). The destinations will be (re)created on the new Drive."
msgstr ""
"   Um mit dem NEUEN Konto fortzufahren: führen Sie „Cache "
"initialisieren“ (oder Zuordnungen zurücksetzen) aus. Die Ziele werden auf "
"dem neuen Drive (neu) erstellt."

#: proton_sync.py:1768
msgid ""
"⏹ Interrupted — cache progress saved: resuming will skip what is already "
"done (no restart from zero)."
msgstr ""
"⏹ Unterbrochen — Cache-Fortschritt gespeichert: bei Fortsetzung wird bereits "
"Erledigtes übersprungen (kein Neustart von null)."

#: proton_sync.py:1777
msgid "DRY-RUN (nothing will be transferred)"
msgstr "DRY-RUN (nichts wird übertragen)"

#: proton_sync.py:1777
msgid "real"
msgstr "echt"

#: proton_sync.py:1786
#, python-brace-format
msgid "== Proton Drive sync — {n} entry(ies) — {m}{x} =="
msgstr "== Proton Drive Synchronisierung — {n} Eintrag/Einträge — {m}{x} =="

#: proton_sync.py:1788
#, python-brace-format
msgid "   Cache: {p} ({n} known folder(s))"
msgstr "   Cache: {p} ({n} bekannte Ordner)"

#: proton_sync.py:1795
msgid ""
"   ↺ Resuming on an existing cache — work already recorded won't be redone "
"(unchanged folders are skipped)."
msgstr ""
"   ↺ Fortsetzung auf vorhandenem Cache — bereits erfasste Arbeit wird nicht "
"wiederholt (unveränderte Ordner werden übersprungen)."

#: proton_sync.py:1800
#, python-brace-format
msgid "   Global exclusions: {n} name(s), {p} pattern(s)"
msgstr "   Globale Ausschlüsse: {n} Name(n), {p} Muster"

#: proton_sync.py:1814
#, python-brace-format
msgid "   ⟳ Restricted to {n} selected mapping(s) (of {t})."
msgstr "   ⟳ Beschränkt auf {n} ausgewählte Zuordnung(en) (von {t})."

#: proton_sync.py:1827
#, python-brace-format
msgid "   ⚠  DELETION mode active — {n} mapping(s) with allow_delete"
msgstr "   ⚠  LÖSCH-Modus aktiv — {n} Zuordnung(en) mit allow_delete"

#: proton_sync.py:1828
#, python-brace-format
msgid ", including {n} PERMANENT"
msgstr ", davon {n} ENDGÜLTIG"

#: proton_sync.py:1830
msgid ""
"   ⚠  mount_check.py missing: ALL deletions will be refused (safety guard)."
msgstr ""
"   ⚠  mount_check.py fehlt: ALLE Löschungen werden verweigert "
"(Sicherheitsvorkehrung)."

#: proton_sync.py:1840
msgid "❌ --subpath requires --mapping-source to identify the mapping."
msgstr ""
"❌ --subpath erfordert --mapping-source zur Identifizierung der Zuordnung."

#: proton_sync.py:1849
#, python-brace-format
msgid "❌ No mapping with source = {s}"
msgstr "❌ Keine Zuordnung mit Quelle = {s}"

#: proton_sync.py:1852
#, python-brace-format
msgid "❌ --subpath only applies to 'folder' mappings (this one is '{t}')."
msgstr "❌ --subpath gilt nur für 'folder'-Zuordnungen (diese ist '{t}')."

#: proton_sync.py:1856
#, python-brace-format
msgid "== REAL-TIME sync — subpath of a mapping — {m} =="
msgstr "== ECHTZEIT-Synchronisierung — Unterpfad einer Zuordnung — {m} =="

#: proton_sync.py:1857
#, python-brace-format
msgid "   Mapping: {s}  =>  {d}"
msgstr "   Zuordnung: {s}  =>  {d}"

#: proton_sync.py:1859
msgid "   ⚠  Deletion propagation requested (--delete)"
msgstr "   ⚠  Löschübertragung angefordert (--delete)"

#: proton_sync.py:1872 proton_sync.py:1939
msgid "Done."
msgstr "Fertig."

#: proton_sync.py:1886
#, python-brace-format
msgid "   ♻ RESET restricted to {n} selected mapping(s) (of {t})."
msgstr ""
"   ♻ ZURÜCKSETZEN beschränkt auf {n} ausgewählte Zuordnung(en) (von {t})."

#: proton_sync.py:1900
#, python-brace-format
msgid "   ♻ {n} cache entry(ies) purged: {s}"
msgstr "   ♻ {n} Cache-Eintrag/Einträge bereinigt: {s}"

#: proton_sync.py:1913
#, python-brace-format
msgid ""
"\n"
"▶ Mapping {i}/{n} : {s}  =>  {d}"
msgstr ""
"\n"
"▶ Zuordnung {i}/{n} : {s}  =>  {d}"

#: proton_sync.py:1915
#, python-brace-format
msgid "  ❌ Source not found, skipped: {s}"
msgstr "  ❌ Quelle nicht gefunden, übersprungen: {s}"

#: realtime_consumer.py:238
#, python-brace-format
msgid "  🔎 self-test marker acknowledged (id {i})."
msgstr "  🔎 Self-test-Marker bestätigt (id {i})."

#: realtime_consumer.py:241
#, python-brace-format
msgid "  ⚠ self-test reply write failed: {e}"
msgstr "  ⚠ Schreiben der Self-test-Antwort fehlgeschlagen: {e}"

#: realtime_consumer.py:461
#, python-brace-format
msgid "  ⊘ folder vanished, skipped: {p}"
msgstr "  ⊘ Ordner verschwunden, übersprungen: {p}"

#: realtime_consumer.py:468
#, python-brace-format
msgid "  ⊘ no mapping for: {p} (marker ignored)"
msgstr "  ⊘ keine Zuordnung für: {p} (Markierung ignoriert)"

#: realtime_consumer.py:473
msgid " [with deletions]"
msgstr " [mit Löschungen]"

#: realtime_consumer.py:474
#, python-brace-format
msgid "  → sync: {p}{f}"
msgstr "  → Synchronisierung: {p}{f}"

#: realtime_consumer.py:489
msgid "    🚫 excluded (name filtered) — nothing to sync"
msgstr "    🚫 ausgeschlossen (Name gefiltert) — nichts zu synchronisieren"

#: realtime_consumer.py:491
msgid "    ✓ ok"
msgstr "    ✓ ok"

#: realtime_consumer.py:506
msgid ""
"    ⏳ cold folder — deferred to the scheduled pass (real-time does not "
"build the cache)"
msgstr ""
"    ⏳ kalter Ordner — auf geplanten Durchlauf verschoben (Echtzeit erstellt "
"den Cache nicht)"

#: realtime_consumer.py:519
msgid ""
"    ⛔ account changed — engine refused (cache belongs to the previous "
"account); markers kept"
msgstr ""
"    ⛔ Konto geändert — Engine verweigert (Cache gehört zum vorherigen "
"Konto); Markierungen behalten"

#: realtime_consumer.py:526
#, python-brace-format
msgid "    ✗ failure (code {c}) — markers kept for retry"
msgstr "    ✗ Fehler (Code {c}) — Markierungen für erneuten Versuch behalten"

#: realtime_consumer.py:762
#, python-brace-format
msgid "Real-time daemon started (user {u})."
msgstr "Echtzeit-Dienst gestartet (Benutzer {u})."

#: realtime_consumer.py:763
#, python-brace-format
msgid "  Engine: {p}"
msgstr "  Engine: {p}"

#: realtime_consumer.py:771
#, python-brace-format
msgid ""
"  • {r}/{t} mapping(s) ready for real-time. The others need a full pass "
"(Schedule) before real-time can sync them."
msgstr ""
"  • {r}/{t} Zuordnung(en) echtzeitbereit. Die anderen benötigen einen "
"vollständigen Durchlauf (Zeitplan), bevor die Echtzeit sie synchronisieren "
"kann."

#: realtime_consumer.py:774
#, python-brace-format
msgid "  • {r}/{t} mapping(s) ready for real-time."
msgstr "  • {r}/{t} Zuordnung(en) echtzeitbereit."

#: realtime_consumer.py:821
msgid "▶ NAS back online — resuming NAS mappings."
msgstr "▶ NAS wieder online — NAS-Mappings werden fortgesetzt."

#: realtime_consumer.py:823
msgid ""
"⏸ NAS unreachable — NAS mappings suspended, local mode active. Local "
"mappings keep syncing."
msgstr ""
"⏸ NAS nicht erreichbar — NAS-Mappings ausgesetzt, lokaler Modus aktiv. "
"Lokale Mappings werden weiter synchronisiert."

#: realtime_consumer.py:826
msgid "NAS disabled — local mode only."
msgstr "NAS deaktiviert — nur lokaler Modus."

#: realtime_consumer.py:853
msgid "🔓 Session opened — starting the pass."
msgstr "🔓 Sitzung geöffnet — Durchlauf wird gestartet."

#: realtime_consumer.py:855
msgid "🔓 Lock released — starting the pass."
msgstr "🔓 Sperre freigegeben — Durchlauf wird gestartet."

#: realtime_consumer.py:857
msgid "🔓 Account matter resolved — starting the pass."
msgstr "🔓 Kontoproblem behoben — Durchlauf wird gestartet."

#: realtime_consumer.py:875
msgid ""
"⏳ Proton authentication unavailable (expired session or locked keyring) — "
"markers kept, no pass launched. Run “proton-drive auth login” (or the “Sign "
"in to Proton” button) to renew the session."
msgstr ""
"⏳ Proton-Authentifizierung nicht verfügbar (abgelaufene Sitzung oder "
"gesperrter Schlüsselbund) — Markierungen behalten, kein Durchlauf gestartet. "
"Führen Sie „proton-drive auth login“ (oder die Schaltfläche „Bei Proton "
"anmelden“) aus, um die Sitzung zu erneuern."

#: realtime_consumer.py:880
msgid ""
"⛔ Proton account changed — the cache belongs to the previous account. "
"Markers kept; prime the cache (or reset the mappings) from the GUI to resume."
msgstr ""
"⛔ Proton-Konto geändert — der Cache gehört zum vorherigen Konto. "
"Markierungen behalten; initialisieren Sie den Cache (oder setzen Sie die "
"Zuordnungen zurück) über die Oberfläche, um fortzufahren."

#: realtime_consumer.py:884
msgid ""
"⏳ Waiting: another pass holds the lock (manual or scheduled run) — markers "
"kept, no pass launched."
msgstr ""
"⏳ Warten: ein anderer Durchlauf hält die Sperre (manueller oder geplanter "
"Lauf) — Markierungen behalten, kein Durchlauf gestartet."

#: realtime_consumer.py:892
msgid "✓ Pass finished."
msgstr "✓ Durchlauf beendet."

#: local_watcher.py:362

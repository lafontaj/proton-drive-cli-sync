#: config.py:314
msgid "The suffix cannot be empty."
msgstr "El sufijo no puede estar vacío."

#: config.py:316
msgid "The suffix cannot contain / \\ \" '."
msgstr "El sufijo no puede contener / \\ \" '."

#: config.py:399
#, python-brace-format
msgid "[config] Data folder migrated: {old} -> {new}"
msgstr "[config] Carpeta de datos migrada: {old} -> {new}"

#: config.py:404
#, python-brace-format
msgid ""
"[config] ⚠ Could not migrate the data folder ({e}) — using the legacy paths "
"for this run."
msgstr ""
"[config] ⚠ No se pudo migrar la carpeta de datos ({e}) — usando las rutas "
"antiguas para esta ejecución."

#: config.py:413
#, python-brace-format
msgid "[config] ⚠ Could not migrate the cache folder ({e})."
msgstr "[config] ⚠ No se pudo migrar la carpeta de caché ({e})."

#: proton_sync.py:208
#, python-brace-format
msgid "    ✎ [DRY-RUN] would fix uppercase extension: {a} -> {b}"
msgstr "    ✎ [DRY-RUN] corregiría la extensión en mayúsculas: {a} -> {b}"

#: proton_sync.py:217
#, python-brace-format
msgid "    ✎ fixed uppercase extension: {a} -> {b}"
msgstr "    ✎ extensión en mayúsculas corregida: {a} -> {b}"

#: proton_sync.py:221
#, python-brace-format
msgid "    ⚠  Could not rename {a}: {e}"
msgstr "    ⚠  No se pudo renombrar {a}: {e}"

#: proton_sync.py:278
#, python-brace-format
msgid "⚠  Cache corrupted or unreadable ({e}) — starting fresh."
msgstr "⚠  Caché dañada o ilegible ({e}) — empezando de cero."

#: proton_sync.py:720
#, python-brace-format
msgid "    ⚠  Could not create {p}: {e}"
msgstr "    ⚠  No se pudo crear {p}: {e}"

#: proton_sync.py:731
#, python-brace-format
msgid "    (nothing found at {p}: {e})"
msgstr "    (no se encontró nada en {p}: {e})"

#: proton_sync.py:738
msgid "    [debug] first raw element received from 'filesystem list -j':"
msgstr ""
"    [debug] primer elemento sin procesar recibido de 'filesystem list -j':"

#: proton_sync.py:773
#, python-brace-format
msgid "    (remote size unknown for {f}, re-sending to be safe)"
msgstr "    (tamaño remoto desconocido para {f}, reenviando por seguridad)"

#: proton_sync.py:781
#, python-brace-format
msgid "    (same size but different content: {f})"
msgstr "    (mismo tamaño pero contenido diferente: {f})"

#: proton_sync.py:876
#, python-brace-format
msgid "    [DRY-RUN] would upload: {p}"
msgstr "    [DRY-RUN] subiría: {p}"

#: proton_sync.py:898
#, python-brace-format
msgid "    ✅ {n} file(s) sent to {p}"
msgstr "    ✅ {n} archivo(s) enviado(s) a {p}"

#: proton_sync.py:904
#, python-brace-format
msgid ""
"    ⚠  Batch upload to {p} reported a failure — isolating the culprit "
"file(s)…"
msgstr ""
"    ⚠  La subida por lotes a {p} informó de un fallo — aislando el/los "
"archivo(s) culpable(s)…"

#: proton_sync.py:923
#, python-brace-format
msgid "      – vanished before upload (deleted meanwhile), skipped: {p}"
msgstr ""
"      – desaparecido antes de la subida (eliminado mientras tanto), omitido: "
"{p}"

#: proton_sync.py:934
#, python-brace-format
msgid "      – vanished during upload (deleted meanwhile), skipped: {p}"
msgstr ""
"      – desaparecido durante la subida (eliminado mientras tanto), omitido: "
"{p}"

#: proton_sync.py:941
#, python-brace-format
msgid "      ⚠ thumbnail/codec issue — retrying without thumbnail: {p}"
msgstr "      ⚠ problema de miniatura/códec — reintentando sin miniatura: {p}"

#: proton_sync.py:945
#, python-brace-format
msgid "      ✓ uploaded WITHOUT thumbnail (no Proton preview): {p}"
msgstr "      ✓ subido SIN miniatura (sin vista previa de Proton): {p}"

#: proton_sync.py:954
#, python-brace-format
msgid "      ✓ recovered on individual retry: {p}"
msgstr "      ✓ recuperado en reintento individual: {p}"

#: proton_sync.py:957
#, python-brace-format
msgid "    ❌ upload failed: {p}"
msgstr "    ❌ subida fallida: {p}"

#: proton_sync.py:958
#, python-brace-format
msgid "    ❌   reason: {e}"
msgstr "    ❌   motivo: {e}"

#: proton_sync.py:958
msgid "(no message from the CLI)"
msgstr "(sin mensaje de la CLI)"

#: proton_sync.py:962
#, python-brace-format
msgid "    ✅ {n} file(s) recovered on individual retry."
msgstr "    ✅ {n} archivo(s) recuperado(s) en reintento individual."

#: proton_sync.py:964
#, python-brace-format
msgid ""
"    ⚠  {n} file(s) uploaded WITHOUT thumbnail (image format needs an OS "
"codec — saved anyway, logged in {log})."
msgstr ""
"    ⚠  {n} archivo(s) subido(s) SIN miniatura (el formato de imagen necesita "
"un códec del SO — guardado igualmente, registrado en {log})."

#: proton_sync.py:967
#, python-brace-format
msgid ""
"    – {n} file(s) vanished (deleted meanwhile) — skipped, not a failure."
msgstr ""
"    – {n} archivo(s) desaparecido(s) (eliminado(s) mientras tanto) — "
"omitido(s), no es un fallo."

#: proton_sync.py:969
#, python-brace-format
msgid "    ❌ {n} file(s) still failing (see the failures log: {log})."
msgstr ""
"    ❌ {n} archivo(s) siguen fallando (consulte el registro de fallos: "
"{log})."

#: proton_sync.py:982
msgid "would delete PERMANENTLY"
msgstr "eliminaría PERMANENTEMENTE"

#: proton_sync.py:982
msgid "would move to trash"
msgstr "movería a la papelera"

#: proton_sync.py:987
#, python-brace-format
msgid "    ❌ {a} of {p} failed: {e}"
msgstr "    ❌ {a} de {p} falló: {e}"

#: proton_sync.py:989
msgid "permanently deleted"
msgstr "eliminado permanentemente"

#: proton_sync.py:989
msgid "sent to trash"
msgstr "enviado a la papelera"

#: proton_sync.py:1027
#, python-brace-format
msgid "    (orphan folder: {n} — ~{c} remote element(s))"
msgstr "    (carpeta huérfana: {n} — ~{c} elemento(s) remoto(s))"

#: proton_sync.py:1059
#, python-brace-format
msgid "  ⛔ Remote wipe REFUSED (mount guard): {r}"
msgstr "  ⛔ Borrado remoto RECHAZADO (protección de montaje): {r}"

#: proton_sync.py:1060
msgid "     Nothing deleted remotely — this mapping was NOT reset."
msgstr ""
"     Nada eliminado de forma remota — esta asignación NO se restableció."

#: proton_sync.py:1065
#, python-brace-format
msgid "  ♻ No remote folder to wipe (already absent): {p}"
msgstr "  ♻ No hay carpeta remota que borrar (ya ausente): {p}"

#: proton_sync.py:1067
#, python-brace-format
msgid "  🗑  Wiping remote folder to TRASH: {p}"
msgstr "  🗑  Borrando carpeta remota a la PAPELERA: {p}"

#: proton_sync.py:1097 proton_sync.py:1114
#, python-brace-format
msgid "  ❌ Could not read {p}: {e}"
msgstr "  ❌ No se pudo leer {p}: {e}"

#: proton_sync.py:1175
#, python-brace-format
msgid "  ⚡ {t}, skipping the CLI call for {p}"
msgstr "  ⚡ {t}, omitiendo la llamada a la CLI para {p}"

#: proton_sync.py:1181
#, python-brace-format
msgid "  🚫 excluded (folder): {p}"
msgstr "  🚫 excluido (carpeta): {p}"

#: proton_sync.py:1214
#, python-brace-format
msgid "    🚫 excluded ({k}): {p}"
msgstr "    🚫 excluido ({k}): {p}"

#: proton_sync.py:1230 proton_sync.py:1318
#, python-brace-format
msgid "    ⏭  unchanged: {p}"
msgstr "    ⏭  sin cambios: {p}"

#: proton_sync.py:1289
#, python-brace-format
msgid "  ⚠  Deletions disabled for this mapping: {r}"
msgstr "  ⚠  Eliminaciones desactivadas para esta asignación: {r}"

#: proton_sync.py:1290 proton_sync.py:1477
msgid "      (uploads continue normally)"
msgstr "      (las subidas continúan con normalidad)"

#: proton_sync.py:1293 proton_sync.py:1480
msgid "permanent"
msgstr "permanente"

#: proton_sync.py:1293 proton_sync.py:1480
msgid "to trash"
msgstr "a la papelera"

#: proton_sync.py:1294
#, python-brace-format
msgid "  🗑  Deletion propagation ACTIVE ({l}) for this mapping"
msgstr "  🗑  Propagación de eliminaciones ACTIVA ({l}) para esta asignación"

#: proton_sync.py:1309
#, python-brace-format
msgid "    🚫 excluded (file): {p}"
msgstr "    🚫 excluido (archivo): {p}"

#: proton_sync.py:1420
#, python-brace-format
msgid "  ❌ Subpath not found or not a folder: {p}"
msgstr "  ❌ Subruta no encontrada o no es una carpeta: {p}"

#: proton_sync.py:1433
#, python-brace-format
msgid "subpath excluded (“{s}” filtered), skipped: {p}"
msgstr "subruta excluida («{s}» filtrada), omitida: {p}"

#: proton_sync.py:1455
#, python-brace-format
msgid ""
"folder not fully indexed yet (cache not built by a full pass), deferred to "
"scheduling: {p}"
msgstr ""
"carpeta aún no indexada por completo (caché no construida por una pasada "
"completa), aplazada a la programación: {p}"

#: proton_sync.py:1476
#, python-brace-format
msgid "  ⚠  Deletions disabled for this subpath: {r}"
msgstr "  ⚠  Eliminaciones desactivadas para esta subruta: {r}"

#: proton_sync.py:1481
#, python-brace-format
msgid "  🗑  Deletion propagation ACTIVE ({l}) for this subpath"
msgstr "  🗑  Propagación de eliminaciones ACTIVA ({l}) para esta subruta"

#: proton_sync.py:1483
#, python-brace-format
msgid "  ↪ subpath: {s}  =>  {d}"
msgstr "  ↪ subruta: {s}  =>  {d}"

#: proton_sync.py:1617
msgid "❌ --wipe-remote requires --reset-source."
msgstr "❌ --wipe-remote requiere --reset-source."

#: proton_sync.py:1638 proton_sync.py:1678
#, python-brace-format
msgid "❌ proton-drive binary not found at {p}"
msgstr "❌ binario proton-drive no encontrado en {p}"

#: proton_sync.py:1660
msgid "❌ A mappings file is required (config)."
msgstr "❌ Se requiere un archivo de asignaciones (configuración)."

#: proton_sync.py:1672
msgid "❌ Another instance of proton_sync.py is already running."
msgstr "❌ Ya se está ejecutando otra instancia de proton_sync.py."

#: proton_sync.py:1673
#, python-brace-format
msgid "   Lock: {p}"
msgstr "   Bloqueo: {p}"

#: proton_sync.py:1674
msgid "   (If you are sure no other instance is running, delete this file.)"
msgstr ""
"   (Si está seguro de que no hay otra instancia en ejecución, elimine este "
"archivo.)"

#: proton_sync.py:1679
msgid "   Adjust the PROTON_DRIVE_CLI environment variable if needed."
msgstr "   Ajuste la variable de entorno PROTON_DRIVE_CLI si es necesario."

#: proton_sync.py:1693
msgid "Proton Drive authentication impossible — pass skipped."
msgstr "Autenticación de Proton Drive imposible — pasada omitida."

#: proton_sync.py:1694
msgid "   Likely cause: the graphical session is not open, so the"
msgstr "   Causa probable: la sesión gráfica no está abierta, por lo que el"

#: proton_sync.py:1695
msgid "   secrets keyring is locked and the CLI cannot read its"
msgstr "   llavero de secretos está bloqueado y la CLI no puede leer sus"

#: proton_sync.py:1696
msgid "   credentials."
msgstr "   credenciales."

#: proton_sync.py:1698
#, python-brace-format
msgid "   CLI detail: {e}"
msgstr "   Detalle de la CLI: {e}"

#: proton_sync.py:1699
msgid "   (This is not a serious error: the next run will retry."
msgstr "   (No es un error grave: la próxima ejecución lo reintentará."

#: proton_sync.py:1700
msgid "    Open this user's session to unlock the keyring.)"
msgstr "    Abra la sesión de este usuario para desbloquear el llavero.)"

#: proton_sync.py:1730
#, python-brace-format
msgid ""
"Account change accepted ({a} → {b}) — the previous cache is discarded and "
"will be rebuilt for the new account."
msgstr ""
"Cambio de cuenta aceptado ({a} → {b}) — la caché anterior se descarta y se "
"reconstruirá para la nueva cuenta."

#: proton_sync.py:1737
#, python-brace-format
msgid ""
"The connected Proton account has changed: this cache was built for {a}, but "
"the session is now {b}."
msgstr ""
"La cuenta de Proton conectada ha cambiado: esta caché se creó para {a}, pero "
"la sesión ahora es {b}."

#: proton_sync.py:1740
msgid ""
"   Nothing was synced or modified — the cache describes the OLD account's "
"Drive."
msgstr ""
"   No se sincronizó ni modificó nada — la caché describe el Drive de la "
"cuenta ANTIGUA."

#: proton_sync.py:1742
msgid ""
"   To proceed on the NEW account: run “Prime the cache” (or reset the "
"mappings). The destinations will be (re)created on the new Drive."
msgstr ""
"   Para continuar en la NUEVA cuenta: ejecute «Inicializar caché» (o "
"restablezca las asignaciones). Los destinos se (re)crearán en el nuevo Drive."

#: proton_sync.py:1768
msgid ""
"⏹ Interrupted — cache progress saved: resuming will skip what is already "
"done (no restart from zero)."
msgstr ""
"⏹ Interrumpido — progreso de la caché guardado: al reanudar se omitirá lo ya "
"hecho (sin reiniciar desde cero)."

#: proton_sync.py:1777
msgid "DRY-RUN (nothing will be transferred)"
msgstr "DRY-RUN (no se transferirá nada)"

#: proton_sync.py:1777
msgid "real"
msgstr "real"

#: proton_sync.py:1786
#, python-brace-format
msgid "== Proton Drive sync — {n} entry(ies) — {m}{x} =="
msgstr "== Sincronización de Proton Drive — {n} entrada(s) — {m}{x} =="

#: proton_sync.py:1788
#, python-brace-format
msgid "   Cache: {p} ({n} known folder(s))"
msgstr "   Caché: {p} ({n} carpeta(s) conocida(s))"

#: proton_sync.py:1795
msgid ""
"   ↺ Resuming on an existing cache — work already recorded won't be redone "
"(unchanged folders are skipped)."
msgstr ""
"   ↺ Reanudando sobre una caché existente — el trabajo ya registrado no se "
"rehará (las carpetas sin cambios se omiten)."

#: proton_sync.py:1800
#, python-brace-format
msgid "   Global exclusions: {n} name(s), {p} pattern(s)"
msgstr "   Exclusiones globales: {n} nombre(s), {p} patrón(es)"

#: proton_sync.py:1814
#, python-brace-format
msgid "   ⟳ Restricted to {n} selected mapping(s) (of {t})."
msgstr "   ⟳ Restringido a {n} asignación(es) seleccionada(s) (de {t})."

#: proton_sync.py:1827
#, python-brace-format
msgid "   ⚠  DELETION mode active — {n} mapping(s) with allow_delete"
msgstr "   ⚠  Modo ELIMINACIÓN activo — {n} asignación(es) con allow_delete"

#: proton_sync.py:1828
#, python-brace-format
msgid ", including {n} PERMANENT"
msgstr ", incluidas {n} PERMANENTES"

#: proton_sync.py:1830
msgid ""
"   ⚠  mount_check.py missing: ALL deletions will be refused (safety guard)."
msgstr ""
"   ⚠  falta mount_check.py: TODAS las eliminaciones se rechazarán "
"(protección de seguridad)."

#: proton_sync.py:1840
msgid "❌ --subpath requires --mapping-source to identify the mapping."
msgstr "❌ --subpath requiere --mapping-source para identificar la asignación."

#: proton_sync.py:1849
#, python-brace-format
msgid "❌ No mapping with source = {s}"
msgstr "❌ Ninguna asignación con origen = {s}"

#: proton_sync.py:1852
#, python-brace-format
msgid "❌ --subpath only applies to 'folder' mappings (this one is '{t}')."
msgstr ""
"❌ --subpath solo se aplica a asignaciones de tipo 'folder' (esta es '{t}')."

#: proton_sync.py:1856
#, python-brace-format
msgid "== REAL-TIME sync — subpath of a mapping — {m} =="
msgstr "== Sincronización en TIEMPO REAL — subruta de una asignación — {m} =="

#: proton_sync.py:1857
#, python-brace-format
msgid "   Mapping: {s}  =>  {d}"
msgstr "   Asignación: {s}  =>  {d}"

#: proton_sync.py:1859
msgid "   ⚠  Deletion propagation requested (--delete)"
msgstr "   ⚠  Propagación de eliminaciones solicitada (--delete)"

#: proton_sync.py:1872 proton_sync.py:1939
msgid "Done."
msgstr "Hecho."

#: proton_sync.py:1886
#, python-brace-format
msgid "   ♻ RESET restricted to {n} selected mapping(s) (of {t})."
msgstr ""
"   ♻ RESTABLECIMIENTO restringido a {n} asignación(es) seleccionada(s) (de "
"{t})."

#: proton_sync.py:1900
#, python-brace-format
msgid "   ♻ {n} cache entry(ies) purged: {s}"
msgstr "   ♻ {n} entrada(s) de caché purgada(s): {s}"

#: proton_sync.py:1913
#, python-brace-format
msgid ""
"\n"
"▶ Mapping {i}/{n} : {s}  =>  {d}"
msgstr ""
"\n"
"▶ Asignación {i}/{n} : {s}  =>  {d}"

#: proton_sync.py:1915
#, python-brace-format
msgid "  ❌ Source not found, skipped: {s}"
msgstr "  ❌ Origen no encontrado, omitido: {s}"

#: realtime_consumer.py:238
#, python-brace-format
msgid "  🔎 self-test marker acknowledged (id {i})."
msgstr "  🔎 marcador de autoprueba confirmado (id {i})."

#: realtime_consumer.py:241
#, python-brace-format
msgid "  ⚠ self-test reply write failed: {e}"
msgstr "  ⚠ fallo al escribir la respuesta de autoprueba: {e}"

#: realtime_consumer.py:461
#, python-brace-format
msgid "  ⊘ folder vanished, skipped: {p}"
msgstr "  ⊘ carpeta desaparecida, omitida: {p}"

#: realtime_consumer.py:468
#, python-brace-format
msgid "  ⊘ no mapping for: {p} (marker ignored)"
msgstr "  ⊘ ninguna asignación para: {p} (marcador ignorado)"

#: realtime_consumer.py:473
msgid " [with deletions]"
msgstr " [con eliminaciones]"

#: realtime_consumer.py:474
#, python-brace-format
msgid "  → sync: {p}{f}"
msgstr "  → sincronización: {p}{f}"

#: realtime_consumer.py:489
msgid "    🚫 excluded (name filtered) — nothing to sync"
msgstr "    🚫 excluido (nombre filtrado) — nada que sincronizar"

#: realtime_consumer.py:491
msgid "    ✓ ok"
msgstr "    ✓ ok"

#: realtime_consumer.py:506
msgid ""
"    ⏳ cold folder — deferred to the scheduled pass (real-time does not "
"build the cache)"
msgstr ""
"    ⏳ carpeta fría — aplazada a la pasada programada (el tiempo real no "
"construye la caché)"

#: realtime_consumer.py:519
msgid ""
"    ⛔ account changed — engine refused (cache belongs to the previous "
"account); markers kept"
msgstr ""
"    ⛔ cuenta cambiada — el motor rechazó (la caché pertenece a la cuenta "
"anterior); marcadores conservados"

#: realtime_consumer.py:526
#, python-brace-format
msgid "    ✗ failure (code {c}) — markers kept for retry"
msgstr "    ✗ fallo (código {c}) — marcadores conservados para reintentar"

#: realtime_consumer.py:762
#, python-brace-format
msgid "Real-time daemon started (user {u})."
msgstr "Servicio en tiempo real iniciado (usuario {u})."

#: realtime_consumer.py:763
#, python-brace-format
msgid "  Engine: {p}"
msgstr "  Motor: {p}"

#: realtime_consumer.py:771
#, python-brace-format
msgid ""
"  • {r}/{t} mapping(s) ready for real-time. The others need a full pass "
"(Schedule) before real-time can sync them."
msgstr ""
"  • {r}/{t} asignación(es) listas para tiempo real. Las demás necesitan una "
"pasada completa (Programación) antes de que el tiempo real pueda "
"sincronizarlas."

#: realtime_consumer.py:774
#, python-brace-format
msgid "  • {r}/{t} mapping(s) ready for real-time."
msgstr "  • {r}/{t} asignación(es) listas para tiempo real."

#: realtime_consumer.py:821
msgid "▶ NAS back online — resuming NAS mappings."
msgstr "▶ NAS de vuelta — reanudando las asignaciones NAS."

#: realtime_consumer.py:823
msgid ""
"⏸ NAS unreachable — NAS mappings suspended, local mode active. Local "
"mappings keep syncing."
msgstr ""
"⏸ NAS inaccesible — asignaciones NAS suspendidas, modo local activo. Las "
"asignaciones locales siguen sincronizándose."

#: realtime_consumer.py:826
msgid "NAS disabled — local mode only."
msgstr "NAS desactivado — solo modo local."

#: realtime_consumer.py:853
msgid "🔓 Session opened — starting the pass."
msgstr "🔓 Sesión abierta — iniciando la pasada."

#: realtime_consumer.py:855
msgid "🔓 Lock released — starting the pass."
msgstr "🔓 Bloqueo liberado — iniciando la pasada."

#: realtime_consumer.py:857
msgid "🔓 Account matter resolved — starting the pass."
msgstr "🔓 Problema de cuenta resuelto — iniciando la pasada."

#: realtime_consumer.py:875
msgid ""
"⏳ Proton authentication unavailable (expired session or locked keyring) — "
"markers kept, no pass launched. Run “proton-drive auth login” (or the “Sign "
"in to Proton” button) to renew the session."
msgstr ""
"⏳ Autenticación de Proton no disponible (sesión caducada o llavero "
"bloqueado) — marcadores conservados, ninguna pasada iniciada. Ejecute "
"«proton-drive auth login» (o el botón «Iniciar sesión en Proton») para "
"renovar la sesión."

#: realtime_consumer.py:880
msgid ""
"⛔ Proton account changed — the cache belongs to the previous account. "
"Markers kept; prime the cache (or reset the mappings) from the GUI to resume."
msgstr ""
"⛔ Cuenta de Proton cambiada — la caché pertenece a la cuenta anterior. "
"Marcadores conservados; inicialice la caché (o restablezca las asignaciones) "
"desde la interfaz para reanudar."

#: realtime_consumer.py:884
msgid ""
"⏳ Waiting: another pass holds the lock (manual or scheduled run) — markers "
"kept, no pass launched."
msgstr ""
"⏳ Esperando: otra pasada tiene el bloqueo (ejecución manual o programada) — "
"marcadores conservados, ninguna pasada iniciada."

#: realtime_consumer.py:892
msgid "✓ Pass finished."
msgstr "✓ Pasada finalizada."

#: local_watcher.py:362
#, python-brace-format
msgid "  ⊘ DELETE ignored (NAS mount unhealthy): {p}"
msgstr "  ⊘ ELIMINACIÓN ignorada (montaje NAS en mal estado): {p}"

#: local_watcher.py:368
#, python-brace-format
msgid "  {t} {p} -> marker on {d}"
msgstr "  {t} {p} -> marcador en {d}"

#: local_watcher.py:370
#, python-brace-format
msgid "  ⚠ marker write failed: {e}"
msgstr "  ⚠ escritura del marcador fallida: {e}"

#: local_watcher.py:405
#, python-brace-format
msgid "  ➕ target added: [{k}] {d}"
msgstr "  ➕ objetivo añadido: [{k}] {d}"

#: local_watcher.py:407
#, python-brace-format

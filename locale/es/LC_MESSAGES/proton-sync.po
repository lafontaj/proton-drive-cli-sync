#: proton_mapping_editor.py:2264
#, python-brace-format
msgid "Removed: {s}"
msgstr "Eliminado: {s}"

#: proton_mapping_editor.py:2289
msgid ""
"• Exact names: one per line (e.g. .caltrash, trash, .Trash-1000). Case-"
"insensitive. Excludes any folder OR file with that name.\n"
"• Patterns: one per line, shell style (e.g. *.tmp, .Trash-*, ~*). The * "
"matches any sequence of characters."
msgstr ""
"• Nombres exactos: uno por línea (p. ej. .caltrash, trash, .Trash-1000). No "
"distingue mayúsculas. Excluye cualquier carpeta O archivo con ese nombre.\n"
"• Patrones: uno por línea, estilo shell (p. ej. *.tmp, .Trash-*, ~*). El * "
"coincide con cualquier secuencia de caracteres."


#: config.py:314
msgid "The suffix cannot be empty."
msgstr "Il suffisso non può essere vuoto."

#: config.py:316
msgid "The suffix cannot contain / \\ \" '."
msgstr "Il suffisso non può contenere / \\ \" '."

#: config.py:399
#, python-brace-format
msgid "[config] Data folder migrated: {old} -> {new}"
msgstr "[config] Cartella dati migrata: {old} -> {new}"

#: config.py:404
#, python-brace-format
msgid ""
"[config] ⚠ Could not migrate the data folder ({e}) — using the legacy paths "
"for this run."
msgstr ""
"[config] ⚠ Impossibile migrare la cartella dati ({e}) — uso i percorsi "
"precedenti per questa esecuzione."

#: config.py:413
#, python-brace-format
msgid "[config] ⚠ Could not migrate the cache folder ({e})."
msgstr "[config] ⚠ Impossibile migrare la cartella della cache ({e})."

#: proton_sync.py:208
#, python-brace-format
msgid "    ✎ [DRY-RUN] would fix uppercase extension: {a} -> {b}"
msgstr "    ✎ [DRY-RUN] correggerebbe l'estensione in maiuscolo: {a} -> {b}"

#: proton_sync.py:217
#, python-brace-format
msgid "    ✎ fixed uppercase extension: {a} -> {b}"
msgstr "    ✎ estensione in maiuscolo corretta: {a} -> {b}"

#: proton_sync.py:221
#, python-brace-format
msgid "    ⚠  Could not rename {a}: {e}"
msgstr "    ⚠  Impossibile rinominare {a}: {e}"

#: proton_sync.py:278
#, python-brace-format
msgid "⚠  Cache corrupted or unreadable ({e}) — starting fresh."
msgstr "⚠  Cache danneggiata o illeggibile ({e}) — ripartenza da zero."

#: proton_sync.py:720
#, python-brace-format
msgid "    ⚠  Could not create {p}: {e}"
msgstr "    ⚠  Impossibile creare {p}: {e}"

#: proton_sync.py:731
#, python-brace-format
msgid "    (nothing found at {p}: {e})"
msgstr "    (nulla trovato in {p}: {e})"

#: proton_sync.py:738
msgid "    [debug] first raw element received from 'filesystem list -j':"
msgstr "    [debug] primo elemento grezzo ricevuto da 'filesystem list -j':"

#: proton_sync.py:773
#, python-brace-format
msgid "    (remote size unknown for {f}, re-sending to be safe)"
msgstr "    (dimensione remota sconosciuta per {f}, reinvio per sicurezza)"

#: proton_sync.py:781
#, python-brace-format
msgid "    (same size but different content: {f})"
msgstr "    (stessa dimensione ma contenuto diverso: {f})"

#: proton_sync.py:876
#, python-brace-format
msgid "    [DRY-RUN] would upload: {p}"
msgstr "    [DRY-RUN] caricherebbe: {p}"

#: proton_sync.py:898
#, python-brace-format
msgid "    ✅ {n} file(s) sent to {p}"
msgstr "    ✅ {n} file inviato/i a {p}"

#: proton_sync.py:904
#, python-brace-format
msgid ""
"    ⚠  Batch upload to {p} reported a failure — isolating the culprit "
"file(s)…"
msgstr ""
"    ⚠  Il caricamento in blocco su {p} ha segnalato un errore — isolamento "
"del/dei file colpevole/i…"

#: proton_sync.py:923
#, python-brace-format
msgid "      – vanished before upload (deleted meanwhile), skipped: {p}"
msgstr ""
"      – scomparso prima del caricamento (eliminato nel frattempo), saltato: "
"{p}"

#: proton_sync.py:934
#, python-brace-format
msgid "      – vanished during upload (deleted meanwhile), skipped: {p}"
msgstr ""
"      – scomparso durante il caricamento (eliminato nel frattempo), saltato: "
"{p}"

#: proton_sync.py:941
#, python-brace-format
msgid "      ⚠ thumbnail/codec issue — retrying without thumbnail: {p}"
msgstr ""
"      ⚠ problema miniatura/codec — nuovo tentativo senza miniatura: {p}"

#: proton_sync.py:945
#, python-brace-format
msgid "      ✓ uploaded WITHOUT thumbnail (no Proton preview): {p}"
msgstr "      ✓ caricato SENZA miniatura (nessuna anteprima Proton): {p}"

#: proton_sync.py:954
#, python-brace-format
msgid "      ✓ recovered on individual retry: {p}"
msgstr "      ✓ recuperato al nuovo tentativo individuale: {p}"

#: proton_sync.py:957
#, python-brace-format
msgid "    ❌ upload failed: {p}"
msgstr "    ❌ caricamento fallito: {p}"

#: proton_sync.py:958
#, python-brace-format
msgid "    ❌   reason: {e}"
msgstr "    ❌   motivo: {e}"

#: proton_sync.py:958
msgid "(no message from the CLI)"
msgstr "(nessun messaggio dalla CLI)"

#: proton_sync.py:962
#, python-brace-format
msgid "    ✅ {n} file(s) recovered on individual retry."
msgstr "    ✅ {n} file recuperato/i al nuovo tentativo individuale."

#: proton_sync.py:964
#, python-brace-format
msgid ""
"    ⚠  {n} file(s) uploaded WITHOUT thumbnail (image format needs an OS "
"codec — saved anyway, logged in {log})."
msgstr ""
"    ⚠  {n} file caricato/i SENZA miniatura (il formato immagine richiede un "
"codec del SO — salvato comunque, registrato in {log})."

#: proton_sync.py:967
#, python-brace-format
msgid ""
"    – {n} file(s) vanished (deleted meanwhile) — skipped, not a failure."
msgstr ""
"    – {n} file scomparso/i (eliminato/i nel frattempo) — saltato/i, non è un "
"errore."

#: proton_sync.py:969
#, python-brace-format
msgid "    ❌ {n} file(s) still failing (see the failures log: {log})."
msgstr ""
"    ❌ {n} file continuano a fallire (vedi il registro degli errori: {log})."

#: proton_sync.py:982
msgid "would delete PERMANENTLY"
msgstr "eliminerebbe PERMANENTEMENTE"

#: proton_sync.py:982
msgid "would move to trash"
msgstr "sposterebbe nel cestino"

#: proton_sync.py:987
#, python-brace-format
msgid "    ❌ {a} of {p} failed: {e}"
msgstr "    ❌ {a} di {p} fallito: {e}"

#: proton_sync.py:989
msgid "permanently deleted"
msgstr "eliminato permanentemente"

#: proton_sync.py:989
msgid "sent to trash"
msgstr "inviato nel cestino"

#: proton_sync.py:1027
#, python-brace-format
msgid "    (orphan folder: {n} — ~{c} remote element(s))"
msgstr "    (cartella orfana: {n} — ~{c} elemento/i remoto/i)"

#: proton_sync.py:1059
#, python-brace-format
msgid "  ⛔ Remote wipe REFUSED (mount guard): {r}"
msgstr "  ⛔ Cancellazione remota RIFIUTATA (protezione di montaggio): {r}"

#: proton_sync.py:1060
msgid "     Nothing deleted remotely — this mapping was NOT reset."
msgstr ""
"     Nulla eliminato in remoto — questa mappatura NON è stata reimpostata."

#: proton_sync.py:1065
#, python-brace-format
msgid "  ♻ No remote folder to wipe (already absent): {p}"
msgstr "  ♻ Nessuna cartella remota da cancellare (già assente): {p}"

#: proton_sync.py:1067
#, python-brace-format
msgid "  🗑  Wiping remote folder to TRASH: {p}"
msgstr "  🗑  Cancellazione della cartella remota nel CESTINO: {p}"

#: proton_sync.py:1097 proton_sync.py:1114
#, python-brace-format
msgid "  ❌ Could not read {p}: {e}"
msgstr "  ❌ Impossibile leggere {p}: {e}"

#: proton_sync.py:1175
#, python-brace-format
msgid "  ⚡ {t}, skipping the CLI call for {p}"
msgstr "  ⚡ {t}, salto la chiamata CLI per {p}"

#: proton_sync.py:1181
#, python-brace-format
msgid "  🚫 excluded (folder): {p}"
msgstr "  🚫 escluso (cartella): {p}"

#: proton_sync.py:1214
#, python-brace-format
msgid "    🚫 excluded ({k}): {p}"
msgstr "    🚫 escluso ({k}): {p}"

#: proton_sync.py:1230 proton_sync.py:1318
#, python-brace-format
msgid "    ⏭  unchanged: {p}"
msgstr "    ⏭  invariato: {p}"

#: proton_sync.py:1289
#, python-brace-format
msgid "  ⚠  Deletions disabled for this mapping: {r}"
msgstr "  ⚠  Eliminazioni disabilitate per questa mappatura: {r}"

#: proton_sync.py:1290 proton_sync.py:1477
msgid "      (uploads continue normally)"
msgstr "      (i caricamenti continuano normalmente)"

#: proton_sync.py:1293 proton_sync.py:1480
msgid "permanent"
msgstr "permanente"

#: proton_sync.py:1293 proton_sync.py:1480
msgid "to trash"
msgstr "nel cestino"

#: proton_sync.py:1294
#, python-brace-format
msgid "  🗑  Deletion propagation ACTIVE ({l}) for this mapping"
msgstr "  🗑  Propagazione delle eliminazioni ATTIVA ({l}) per questa mappatura"

#: proton_sync.py:1309
#, python-brace-format
msgid "    🚫 excluded (file): {p}"
msgstr "    🚫 escluso (file): {p}"

#: proton_sync.py:1420
#, python-brace-format
msgid "  ❌ Subpath not found or not a folder: {p}"
msgstr "  ❌ Sottopercorso non trovato o non è una cartella: {p}"

#: proton_sync.py:1433
#, python-brace-format
msgid "subpath excluded (“{s}” filtered), skipped: {p}"
msgstr "sottopercorso escluso («{s}» filtrato), saltato: {p}"

#: proton_sync.py:1455
#, python-brace-format
msgid ""
"folder not fully indexed yet (cache not built by a full pass), deferred to "
"scheduling: {p}"
msgstr ""
"cartella non ancora completamente indicizzata (cache non costruita da una "
"passata completa), rinviata alla pianificazione: {p}"

#: proton_sync.py:1476
#, python-brace-format
msgid "  ⚠  Deletions disabled for this subpath: {r}"
msgstr "  ⚠  Eliminazioni disabilitate per questo sottopercorso: {r}"

#: proton_sync.py:1481
#, python-brace-format
msgid "  🗑  Deletion propagation ACTIVE ({l}) for this subpath"
msgstr ""
"  🗑  Propagazione delle eliminazioni ATTIVA ({l}) per questo sottopercorso"

#: proton_sync.py:1483
#, python-brace-format
msgid "  ↪ subpath: {s}  =>  {d}"
msgstr "  ↪ sottopercorso: {s}  =>  {d}"

#: proton_sync.py:1617
msgid "❌ --wipe-remote requires --reset-source."
msgstr "❌ --wipe-remote richiede --reset-source."

#: proton_sync.py:1638 proton_sync.py:1678
#, python-brace-format
msgid "❌ proton-drive binary not found at {p}"
msgstr "❌ binario proton-drive non trovato in {p}"

#: proton_sync.py:1660
msgid "❌ A mappings file is required (config)."
msgstr "❌ È richiesto un file di mappature (configurazione)."

#: proton_sync.py:1672
msgid "❌ Another instance of proton_sync.py is already running."
msgstr "❌ Un'altra istanza di proton_sync.py è già in esecuzione."

#: proton_sync.py:1673
#, python-brace-format
msgid "   Lock: {p}"
msgstr "   Blocco: {p}"

#: proton_sync.py:1674
msgid "   (If you are sure no other instance is running, delete this file.)"
msgstr ""
"   (Se sei sicuro che nessun'altra istanza sia in esecuzione, elimina questo "
"file.)"

#: proton_sync.py:1679
msgid "   Adjust the PROTON_DRIVE_CLI environment variable if needed."
msgstr "   Regola la variabile d'ambiente PROTON_DRIVE_CLI se necessario."

#: proton_sync.py:1693
msgid "Proton Drive authentication impossible — pass skipped."
msgstr "Autenticazione Proton Drive impossibile — passata saltata."

#: proton_sync.py:1694
msgid "   Likely cause: the graphical session is not open, so the"
msgstr "   Causa probabile: la sessione grafica non è aperta, quindi il"

#: proton_sync.py:1695
msgid "   secrets keyring is locked and the CLI cannot read its"
msgstr "   portachiavi dei segreti è bloccato e la CLI non può leggere le sue"

#: proton_sync.py:1696
msgid "   credentials."
msgstr "   credenziali."

#: proton_sync.py:1698
#, python-brace-format
msgid "   CLI detail: {e}"
msgstr "   Dettaglio CLI: {e}"

#: proton_sync.py:1699
msgid "   (This is not a serious error: the next run will retry."
msgstr "   (Non è un errore grave: la prossima esecuzione riproverà."

#: proton_sync.py:1700
msgid "    Open this user's session to unlock the keyring.)"
msgstr "    Apri la sessione di questo utente per sbloccare il portachiavi.)"

#: proton_sync.py:1730
#, python-brace-format
msgid ""
"Account change accepted ({a} → {b}) — the previous cache is discarded and "
"will be rebuilt for the new account."
msgstr ""
"Cambio di account accettato ({a} → {b}) — la cache precedente viene scartata "
"e verrà ricostruita per il nuovo account."

#: proton_sync.py:1737
#, python-brace-format
msgid ""
"The connected Proton account has changed: this cache was built for {a}, but "
"the session is now {b}."
msgstr ""
"L'account Proton connesso è cambiato: questa cache è stata creata per {a}, "
"ma la sessione ora è {b}."

#: proton_sync.py:1740
msgid ""
"   Nothing was synced or modified — the cache describes the OLD account's "
"Drive."
msgstr ""
"   Nulla è stato sincronizzato o modificato — la cache descrive il Drive del "
"VECCHIO account."

#: proton_sync.py:1742
msgid ""
"   To proceed on the NEW account: run “Prime the cache” (or reset the "
"mappings). The destinations will be (re)created on the new Drive."
msgstr ""
"   Per procedere sul NUOVO account: esegui «Inizializza cache» (o reimposta "
"le mappature). Le destinazioni verranno (ri)create sul nuovo Drive."

#: proton_sync.py:1768
msgid ""
"⏹ Interrupted — cache progress saved: resuming will skip what is already "
"done (no restart from zero)."
msgstr ""
"⏹ Interrotto — avanzamento della cache salvato: alla ripresa verrà saltato "
"ciò che è già fatto (nessun riavvio da zero)."

#: proton_sync.py:1777
msgid "DRY-RUN (nothing will be transferred)"
msgstr "DRY-RUN (non verrà trasferito nulla)"

#: proton_sync.py:1777
msgid "real"
msgstr "reale"

#: proton_sync.py:1786
#, python-brace-format
msgid "== Proton Drive sync — {n} entry(ies) — {m}{x} =="
msgstr "== Sincronizzazione Proton Drive — {n} voce/i — {m}{x} =="

#: proton_sync.py:1788
#, python-brace-format
msgid "   Cache: {p} ({n} known folder(s))"
msgstr "   Cache: {p} ({n} cartella/e nota/e)"

#: proton_sync.py:1795
msgid ""
"   ↺ Resuming on an existing cache — work already recorded won't be redone "
"(unchanged folders are skipped)."
msgstr ""
"   ↺ Ripresa su una cache esistente — il lavoro già registrato non verrà "
"rifatto (le cartelle invariate vengono saltate)."

#: proton_sync.py:1800
#, python-brace-format
msgid "   Global exclusions: {n} name(s), {p} pattern(s)"
msgstr "   Esclusioni globali: {n} nome/i, {p} criterio/i"

#: proton_sync.py:1814
#, python-brace-format
msgid "   ⟳ Restricted to {n} selected mapping(s) (of {t})."
msgstr "   ⟳ Limitato a {n} mappatura/e selezionata/e (di {t})."

#: proton_sync.py:1827
#, python-brace-format
msgid "   ⚠  DELETION mode active — {n} mapping(s) with allow_delete"
msgstr "   ⚠  Modalità ELIMINAZIONE attiva — {n} mappatura/e con allow_delete"

#: proton_sync.py:1828
#, python-brace-format
msgid ", including {n} PERMANENT"
msgstr ", incluse {n} PERMANENTI"

#: proton_sync.py:1830
msgid ""
"   ⚠  mount_check.py missing: ALL deletions will be refused (safety guard)."
msgstr ""
"   ⚠  mount_check.py mancante: TUTTE le eliminazioni verranno rifiutate "
"(protezione di sicurezza)."

#: proton_sync.py:1840
msgid "❌ --subpath requires --mapping-source to identify the mapping."
msgstr "❌ --subpath richiede --mapping-source per identificare la mappatura."

#: proton_sync.py:1849
#, python-brace-format
msgid "❌ No mapping with source = {s}"
msgstr "❌ Nessuna mappatura con origine = {s}"

#: proton_sync.py:1852
#, python-brace-format
msgid "❌ --subpath only applies to 'folder' mappings (this one is '{t}')."
msgstr ""
"❌ --subpath si applica solo alle mappature di tipo 'folder' (questa è "
"'{t}')."

#: proton_sync.py:1856
#, python-brace-format
msgid "== REAL-TIME sync — subpath of a mapping — {m} =="
msgstr ""
"== Sincronizzazione in TEMPO REALE — sottopercorso di una mappatura — {m} =="

#: proton_sync.py:1857
#, python-brace-format
msgid "   Mapping: {s}  =>  {d}"
msgstr "   Mappatura: {s}  =>  {d}"

#: proton_sync.py:1859
msgid "   ⚠  Deletion propagation requested (--delete)"
msgstr "   ⚠  Propagazione delle eliminazioni richiesta (--delete)"

#: proton_sync.py:1872 proton_sync.py:1939
msgid "Done."
msgstr "Fatto."

#: proton_sync.py:1886
#, python-brace-format
msgid "   ♻ RESET restricted to {n} selected mapping(s) (of {t})."
msgstr "   ♻ REIMPOSTAZIONE limitata a {n} mappatura/e selezionata/e (di {t})."

#: proton_sync.py:1900
#, python-brace-format
msgid "   ♻ {n} cache entry(ies) purged: {s}"
msgstr "   ♻ {n} voce/i di cache eliminata/e: {s}"

#: proton_sync.py:1913
#, python-brace-format
msgid ""
"\n"
"▶ Mapping {i}/{n} : {s}  =>  {d}"
msgstr ""
"\n"
"▶ Mappatura {i}/{n} : {s}  =>  {d}"

#: proton_sync.py:1915
#, python-brace-format
msgid "  ❌ Source not found, skipped: {s}"
msgstr "  ❌ Origine non trovata, saltata: {s}"

#: realtime_consumer.py:238
#, python-brace-format
msgid "  🔎 self-test marker acknowledged (id {i})."
msgstr "  🔎 marcatore di autotest confermato (id {i})."

#: realtime_consumer.py:241
#, python-brace-format
msgid "  ⚠ self-test reply write failed: {e}"
msgstr "  ⚠ scrittura risposta autotest fallita: {e}"

#: realtime_consumer.py:461
#, python-brace-format
msgid "  ⊘ folder vanished, skipped: {p}"
msgstr "  ⊘ cartella scomparsa, saltata: {p}"

#: realtime_consumer.py:468
#, python-brace-format
msgid "  ⊘ no mapping for: {p} (marker ignored)"
msgstr "  ⊘ nessuna mappatura per: {p} (marcatore ignorato)"

#: realtime_consumer.py:473
msgid " [with deletions]"
msgstr " [con eliminazioni]"

#: realtime_consumer.py:474
#, python-brace-format
msgid "  → sync: {p}{f}"
msgstr "  → sincronizzazione: {p}{f}"

#: realtime_consumer.py:489
msgid "    🚫 excluded (name filtered) — nothing to sync"
msgstr "    🚫 escluso (nome filtrato) — niente da sincronizzare"

#: realtime_consumer.py:491
msgid "    ✓ ok"
msgstr "    ✓ ok"

#: realtime_consumer.py:506
msgid ""
"    ⏳ cold folder — deferred to the scheduled pass (real-time does not "
"build the cache)"
msgstr ""
"    ⏳ cartella fredda — rinviata alla passata pianificata (il tempo reale "
"non costruisce la cache)"

#: realtime_consumer.py:519
msgid ""
"    ⛔ account changed — engine refused (cache belongs to the previous "
"account); markers kept"
msgstr ""
"    ⛔ account cambiato — il motore ha rifiutato (la cache appartiene "
"all'account precedente); marcatori conservati"

#: realtime_consumer.py:526
#, python-brace-format
msgid "    ✗ failure (code {c}) — markers kept for retry"
msgstr "    ✗ errore (codice {c}) — marcatori conservati per riprovare"

#: realtime_consumer.py:762
#, python-brace-format
msgid "Real-time daemon started (user {u})."
msgstr "Servizio in tempo reale avviato (utente {u})."

#: realtime_consumer.py:763
#, python-brace-format
msgid "  Engine: {p}"
msgstr "  Motore: {p}"

#: realtime_consumer.py:771
#, python-brace-format
msgid ""
"  • {r}/{t} mapping(s) ready for real-time. The others need a full pass "
"(Schedule) before real-time can sync them."
msgstr ""
"  • {r}/{t} mappatura/e pronte per il tempo reale. Le altre necessitano di "
"una passata completa (Pianificazione) prima che il tempo reale possa "
"sincronizzarle."

#: realtime_consumer.py:774
#, python-brace-format
msgid "  • {r}/{t} mapping(s) ready for real-time."
msgstr "  • {r}/{t} mappatura/e pronte per il tempo reale."

#: realtime_consumer.py:821
msgid "▶ NAS back online — resuming NAS mappings."
msgstr "▶ NAS di nuovo online — ripresa dei mapping NAS."

#: realtime_consumer.py:823
msgid ""
"⏸ NAS unreachable — NAS mappings suspended, local mode active. Local "
"mappings keep syncing."
msgstr ""
"⏸ NAS irraggiungibile — mapping NAS sospesi, modalità locale attiva. I "
"mapping locali continuano a sincronizzarsi."

#: realtime_consumer.py:826
msgid "NAS disabled — local mode only."
msgstr "NAS disattivato — solo modalità locale."

#: realtime_consumer.py:853
msgid "🔓 Session opened — starting the pass."
msgstr "🔓 Sessione aperta — avvio del passaggio."

#: realtime_consumer.py:855
msgid "🔓 Lock released — starting the pass."
msgstr "🔓 Blocco rilasciato — avvio del passaggio."

#: realtime_consumer.py:857
msgid "🔓 Account matter resolved — starting the pass."
msgstr "🔓 Problema dell'account risolto — avvio del passaggio."

#: realtime_consumer.py:875
msgid ""
"⏳ Proton authentication unavailable (expired session or locked keyring) — "
"markers kept, no pass launched. Run “proton-drive auth login” (or the “Sign "
"in to Proton” button) to renew the session."
msgstr ""
"⏳ Autenticazione Proton non disponibile (sessione scaduta o portachiavi "
"bloccato) — marcatori conservati, nessuna passata avviata. Esegui «proton-"
"drive auth login» (o il pulsante «Accedi a Proton») per rinnovare la "
"sessione."

#: realtime_consumer.py:880
msgid ""
"⛔ Proton account changed — the cache belongs to the previous account. "
"Markers kept; prime the cache (or reset the mappings) from the GUI to resume."
msgstr ""
"⛔ Account Proton cambiato — la cache appartiene all'account precedente. "
"Marcatori conservati; inizializza la cache (o reimposta le mappature) "
"dall'interfaccia per riprendere."

#: realtime_consumer.py:884
msgid ""
"⏳ Waiting: another pass holds the lock (manual or scheduled run) — markers "
"kept, no pass launched."
msgstr ""
"⏳ In attesa: un'altra passata detiene il blocco (esecuzione manuale o "
"pianificata) — marcatori conservati, nessuna passata avviata."

#: realtime_consumer.py:892
msgid "✓ Pass finished."
msgstr "✓ Passaggio completato."

#: local_watcher.py:362
#, python-brace-format
msgid "  ⊘ DELETE ignored (NAS mount unhealthy): {p}"
msgstr "  ⊘ ELIMINAZIONE ignorata (montaggio NAS non integro): {p}"

#: local_watcher.py:368
#, python-brace-format
msgid "  {t} {p} -> marker on {d}"
msgstr "  {t} {p} -> marcatore su {d}"

#: local_watcher.py:370
#, python-brace-format
msgid "  ⚠ marker write failed: {e}"
msgstr "  ⚠ scrittura del marcatore fallita: {e}"

#: local_watcher.py:405
#, python-brace-format
msgid "  ➕ target added: [{k}] {d}"
msgstr "  ➕ destinazione aggiunta: [{k}] {d}"

#: local_watcher.py:407

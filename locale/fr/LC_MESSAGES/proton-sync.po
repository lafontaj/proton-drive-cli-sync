msgid "❌ Another instance of proton_sync.py is already running."
msgstr "❌ Une autre instance de proton_sync.py est déjà en cours d'exécution."

#: proton_sync.py:1673
#, python-brace-format
msgid "   Lock: {p}"
msgstr "   Verrou : {p}"

#: proton_sync.py:1674
msgid "   (If you are sure no other instance is running, delete this file.)"
msgstr ""
"   (Si tu es certain qu'aucune autre instance ne tourne, supprime ce "
"fichier.)"

#: proton_sync.py:1679
msgid "   Adjust the PROTON_DRIVE_CLI environment variable if needed."
msgstr "   Ajuste la variable d'environnement PROTON_DRIVE_CLI si besoin."

#: proton_sync.py:1693
msgid "Proton Drive authentication impossible — pass skipped."
msgstr "⚠  Authentification Proton Drive impossible — passage ignoré."

#: proton_sync.py:1694
msgid "   Likely cause: the graphical session is not open, so the"
msgstr "   Cause probable : la session graphique n'est pas ouverte, donc"

#: proton_sync.py:1695
msgid "   secrets keyring is locked and the CLI cannot read its"
msgstr "   le trousseau de secrets est verrouillé et le CLI ne peut pas"

#: proton_sync.py:1696
msgid "   credentials."
msgstr "   lire ses identifiants."

#: proton_sync.py:1698
#, python-brace-format
msgid "   CLI detail: {e}"
msgstr "   Détail du CLI : {e}"

#: proton_sync.py:1699
msgid "   (This is not a serious error: the next run will retry."
msgstr "   (Ce n'est pas une erreur grave : la prochaine exécution réessaiera."

#: proton_sync.py:1700
msgid "    Open this user's session to unlock the keyring.)"
msgstr ""
"    Ouvre la session de cet utilisateur pour déverrouiller le trousseau.)"

#: proton_sync.py:1730
#, python-brace-format
msgid ""
"Account change accepted ({a} → {b}) — the previous cache is discarded and "
"will be rebuilt for the new account."
msgstr ""
"Changement de compte accepté ({a} → {b}) — l'ancien cache est écarté et sera "
"reconstruit pour le nouveau compte."

#: proton_sync.py:1737
#, python-brace-format
msgid ""
"The connected Proton account has changed: this cache was built for {a}, but "
"the session is now {b}."
msgstr ""
"Le compte Proton connecté a changé : ce cache a été bâti pour {a}, mais la "
"session est maintenant {b}."

#: proton_sync.py:1740
msgid ""
"   Nothing was synced or modified — the cache describes the OLD account's "
"Drive."
msgstr ""
"   Rien n'a été synchronisé ni modifié — le cache décrit le Drive de "
"l'ANCIEN compte."

#: proton_sync.py:1742
msgid ""
"   To proceed on the NEW account: run “Prime the cache” (or reset the "
"mappings). The destinations will be (re)created on the new Drive."
msgstr ""
"   Pour continuer sur le NOUVEAU compte : lance « Amorcer le cache » (ou "
"réinitialise les mappings). Les destinations seront (re)créées sur le "
"nouveau Drive."

#: proton_sync.py:1768
msgid ""
"⏹ Interrupted — cache progress saved: resuming will skip what is already "
"done (no restart from zero)."
msgstr ""
"⏹ Interrompu — progression du cache enregistrée : la reprise sautera ce qui "
"est déjà fait (pas de redémarrage à zéro)."

#: proton_sync.py:1777
msgid "DRY-RUN (nothing will be transferred)"
msgstr "DRY-RUN (rien ne sera transféré)"

#: proton_sync.py:1777
msgid "real"
msgstr "réel"

#: proton_sync.py:1786
#, python-brace-format
msgid "== Proton Drive sync — {n} entry(ies) — {m}{x} =="
msgstr "== Synchro Proton Drive — {n} entrée(s) — {m}{x} =="

#: proton_sync.py:1788
#, python-brace-format
msgid "   Cache: {p} ({n} known folder(s))"
msgstr "   Cache : {p} ({n} dossier(s) connu(s))"

#: proton_sync.py:1795
msgid ""
"   ↺ Resuming on an existing cache — work already recorded won't be redone "
"(unchanged folders are skipped)."
msgstr ""
"   ↺ Reprise sur un cache existant — le travail déjà enregistré ne sera pas "
"refait (les dossiers inchangés sont sautés)."

#: proton_sync.py:1800
#, python-brace-format
msgid "   Global exclusions: {n} name(s), {p} pattern(s)"
msgstr "   Exclusions globales : {n} nom(s), {p} motif(s)"

#: proton_sync.py:1814
#, python-brace-format
msgid "   ⟳ Restricted to {n} selected mapping(s) (of {t})."
msgstr "   ⟳ Restreint à {n} mapping(s) sélectionné(s) (sur {t})."

#: proton_sync.py:1827
#, python-brace-format
msgid "   ⚠  DELETION mode active — {n} mapping(s) with allow_delete"
msgstr "   ⚠  Mode SUPPRESSION actif — {n} mapping(s) avec allow_delete"

#: proton_sync.py:1828
#, python-brace-format
msgid ", including {n} PERMANENT"
msgstr ", dont {n} en DÉFINITIF"

#: proton_sync.py:1830
msgid ""
"   ⚠  mount_check.py missing: ALL deletions will be refused (safety guard)."
msgstr ""
"   ⚠  mount_check.py absent : les suppressions seront TOUTES refusées (garde-"
"fou de sécurité)."

#: proton_sync.py:1840
msgid "❌ --subpath requires --mapping-source to identify the mapping."
msgstr "❌ --subpath requiert --mapping-source pour identifier le mapping."

#: proton_sync.py:1849
#, python-brace-format
msgid "❌ No mapping with source = {s}"
msgstr "❌ Aucun mapping avec source = {s}"

#: proton_sync.py:1852
#, python-brace-format
msgid "❌ --subpath only applies to 'folder' mappings (this one is '{t}')."
msgstr ""
"❌ --subpath ne s'applique qu'aux mappings de type 'folder' (celui-ci est "
"'{t}')."

#: proton_sync.py:1856
#, python-brace-format
msgid "== REAL-TIME sync — subpath of a mapping — {m} =="
msgstr "== Synchro TEMPS RÉEL — sous-chemin d'un mapping — {m} =="

#: proton_sync.py:1857
#, python-brace-format
msgid "   Mapping: {s}  =>  {d}"
msgstr "   Mapping : {s}  =>  {d}"

#: proton_sync.py:1859
msgid "   ⚠  Deletion propagation requested (--delete)"
msgstr "   ⚠  Propagation des suppressions demandée (--delete)"

#: proton_sync.py:1872 proton_sync.py:1939
msgid "Done."
msgstr "Terminé."

#: proton_sync.py:1886
#, python-brace-format
msgid "   ♻ RESET restricted to {n} selected mapping(s) (of {t})."
msgstr ""
"   ♻ RÉINITIALISATION restreinte à {n} mapping(s) sélectionné(s) (sur {t})."

#: proton_sync.py:1900
#, python-brace-format
msgid "   ♻ {n} cache entry(ies) purged: {s}"
msgstr "   ♻ {n} entrée(s) de cache purgée(s) : {s}"

#: proton_sync.py:1913
#, python-brace-format
msgid ""
"\n"
"▶ Mapping {i}/{n} : {s}  =>  {d}"
msgstr ""
"\n"
"▶ Mapping {i}/{n} : {s}  =>  {d}"

#: proton_sync.py:1915
#, python-brace-format
msgid "  ❌ Source not found, skipped: {s}"
msgstr "  ❌ Source introuvable, ignoré : {s}"

#: realtime_consumer.py:238
#, python-brace-format
msgid "  🔎 self-test marker acknowledged (id {i})."
msgstr "  🔎 marqueur de self-test acquitté (id {i})."

#: realtime_consumer.py:241
#, python-brace-format
msgid "  ⚠ self-test reply write failed: {e}"
msgstr "  ⚠ échec d'écriture de la réponse self-test : {e}"

#: realtime_consumer.py:461
#, python-brace-format
msgid "  ⊘ folder vanished, skipped: {p}"
msgstr "  ⊘ dossier disparu, sauté : {p}"

#: realtime_consumer.py:468
#, python-brace-format
msgid "  ⊘ no mapping for: {p} (marker ignored)"
msgstr "  ⊘ aucun mapping pour : {p} (marqueur ignoré)"

#: realtime_consumer.py:473
msgid " [with deletions]"
msgstr " [avec suppressions]"

#: realtime_consumer.py:474
#, python-brace-format
msgid "  → sync: {p}{f}"
msgstr "  → synchro : {p}{f}"

#: realtime_consumer.py:489
msgid "    🚫 excluded (name filtered) — nothing to sync"
msgstr "    🚫 exclu (nom filtré) — rien à synchroniser"

#: realtime_consumer.py:491
msgid "    ✓ ok"
msgstr "    ✓ ok"

#: realtime_consumer.py:506
msgid ""
"    ⏳ cold folder — deferred to the scheduled pass (real-time does not "
"build the cache)"
msgstr ""
"    ⏳ dossier pas encore analysé — différé au passage planifié (le temps "
"réel ne bâtit pas le cache)"

#: realtime_consumer.py:519
msgid ""
"    ⛔ account changed — engine refused (cache belongs to the previous "
"account); markers kept"
msgstr ""
"    ⛔ compte changé — moteur en refus (le cache appartient à l'ancien "
"compte) ; marqueurs conservés"

#: realtime_consumer.py:526
#, python-brace-format
msgid "    ✗ failure (code {c}) — markers kept for retry"
msgstr "    ✗ échec (code {c}) — marqueurs conservés pour réessai"

#: realtime_consumer.py:762
#, python-brace-format
msgid "Real-time daemon started (user {u})."
msgstr "Démon temps réel démarré (utilisateur {u})."

#: realtime_consumer.py:763
#, python-brace-format
msgid "  Engine: {p}"
msgstr "  Moteur : {p}"

#: realtime_consumer.py:771
#, python-brace-format
msgid ""
"  • {r}/{t} mapping(s) ready for real-time. The others need a full pass "
"(Schedule) before real-time can sync them."
msgstr ""
"  • {r}/{t} mapping(s) prêt(s) pour le temps réel. Les autres nécessitent un "
"passage complet (Planification) avant que le temps réel puisse les "
"synchroniser."

#: realtime_consumer.py:774
#, python-brace-format
msgid "  • {r}/{t} mapping(s) ready for real-time."
msgstr "  • {r}/{t} mapping(s) prêt(s) pour le temps réel."

#: realtime_consumer.py:821
msgid "▶ NAS back online — resuming NAS mappings."
msgstr "▶ NAS de retour — reprise des mappings NAS."

#: realtime_consumer.py:823
msgid ""
"⏸ NAS unreachable — NAS mappings suspended, local mode active. Local "
"mappings keep syncing."
msgstr ""
"⏸ NAS injoignable — mappings NAS suspendus, mode local actif. Les mappings "
"locaux continuent de se synchroniser."

#: realtime_consumer.py:826
msgid "NAS disabled — local mode only."
msgstr "NAS désactivé — mode local uniquement."

#: realtime_consumer.py:853
msgid "🔓 Session opened — starting the pass."
msgstr "🔓 Session ouverte — lancement du passage."

#: realtime_consumer.py:855
msgid "🔓 Lock released — starting the pass."
msgstr "🔓 Verrou libéré — lancement du passage."

#: realtime_consumer.py:857
msgid "🔓 Account matter resolved — starting the pass."
msgstr "🔓 Problème de compte résolu — lancement du passage."

#: realtime_consumer.py:875
msgid ""
"⏳ Proton authentication unavailable (expired session or locked keyring) — "
"markers kept, no pass launched. Run “proton-drive auth login” (or the “Sign "
"in to Proton” button) to renew the session."
msgstr ""
"⏳ Authentification Proton indisponible (session expirée ou trousseau "
"verrouillé) — marqueurs conservés, aucun passage lancé. Lancez « proton-"
"drive auth login » (ou le bouton « Se connecter à Proton ») pour renouveler "
"la session."

#: realtime_consumer.py:880
msgid ""
"⛔ Proton account changed — the cache belongs to the previous account. "
"Markers kept; prime the cache (or reset the mappings) from the GUI to resume."
msgstr ""
"⛔ Compte Proton changé — le cache appartient à l'ancien compte. Marqueurs "
"conservés ; amorce le cache (ou réinitialise les mappings) depuis le GUI "
"pour reprendre."

#: realtime_consumer.py:884
msgid ""
"⏳ Waiting: another pass holds the lock (manual or scheduled run) — markers "
"kept, no pass launched."
msgstr ""
"⏳ En attente : un autre passage tient le verrou (lancement manuel ou "
"planifié) — marqueurs conservés, aucun passage lancé."

#: realtime_consumer.py:892
msgid "✓ Pass finished."
msgstr "✓ Passage terminé."

#: local_watcher.py:362
#, python-brace-format
msgid "  ⊘ DELETE ignored (NAS mount unhealthy): {p}"
msgstr "  ⊘ DELETE ignoré (montage NAS non sain) : {p}"

#: local_watcher.py:368
#, python-brace-format
msgid "  {t} {p} -> marker on {d}"
msgstr "  {t} {p} -> marqueur sur {d}"

#: local_watcher.py:370
#, python-brace-format
msgid "  ⚠ marker write failed: {e}"
msgstr "  ⚠ écriture marqueur échouée : {e}"

#: local_watcher.py:405
#, python-brace-format
msgid "  ➕ target added: [{k}] {d}"
msgstr "  ➕ cible ajoutée : [{k}] {d}"

#: local_watcher.py:407
#, python-brace-format
msgid "  ⚠ cannot watch {d}: {e}"
msgstr "  ⚠ impossible de surveiller {d} : {e}"

#: local_watcher.py:417
#, python-brace-format
msgid "  ➖ target removed (mount down or source deleted): {d}"
msgstr "  ➖ cible retirée (montage tombé ou source supprimée) : {d}"

#: local_watcher.py:424

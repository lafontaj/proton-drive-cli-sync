msgstr "    ⚠  Échec du lot vers {p} — isolement du/des fichier(s) fautif(s)…"

#: proton_sync.py:923
#, python-brace-format
msgid "      – vanished before upload (deleted meanwhile), skipped: {p}"
msgstr "      – disparu avant l'upload (supprimé entre-temps), ignoré : {p}"


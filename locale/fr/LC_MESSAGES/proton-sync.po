#: config.py:314
msgid "The suffix cannot be empty."
msgstr "Le suffixe ne peut pas être vide."

#: config.py:316
msgid "The suffix cannot contain / \\ \" '."
msgstr "Le suffixe ne peut pas contenir / \\ \" '."

#: config.py:399
#, python-brace-format
msgid "[config] Data folder migrated: {old} -> {new}"
msgstr "[config] Dossier de données migré : {old} -> {new}"

#: config.py:404
#, python-brace-format
msgid ""
"[config] ⚠ Could not migrate the data folder ({e}) — using the legacy paths "

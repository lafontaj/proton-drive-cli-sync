msgstr "(aucun message du CLI)"

#: proton_sync.py:962
#, python-brace-format
msgid "    ✅ {n} file(s) recovered on individual retry."
msgstr "    ✅ {n} fichier(s) récupéré(s) au ré-essai individuel."

#: proton_sync.py:964
#, python-brace-format
msgid ""
"    ⚠  {n} file(s) uploaded WITHOUT thumbnail (image format needs an OS "
"codec — saved anyway, logged in {log})."
msgstr ""
"    ⚠  {n} fichier(s) téléversé(s) SANS vignette (le format image requiert "
"un codec OS — sauvegardé(s) quand même, consigné(s) dans {log})."

#: proton_sync.py:967
#, python-brace-format
msgid ""
"    – {n} file(s) vanished (deleted meanwhile) — skipped, not a failure."
msgstr ""
"    – {n} fichier(s) disparu(s) (supprimé(s) entre-temps) — ignoré(s), pas "
"un échec."

#: proton_sync.py:969
#, python-brace-format
msgid "    ❌ {n} file(s) still failing (see the failures log: {log})."
msgstr ""
"    ❌ {n} fichier(s) encore en échec (voir le journal d'échecs : {log})."

#: proton_sync.py:982
msgid "would delete PERMANENTLY"
msgstr "supprimerait DÉFINITIVEMENT"

#: proton_sync.py:982
msgid "would move to trash"
msgstr "mettrait à la corbeille"


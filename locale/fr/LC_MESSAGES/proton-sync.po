#, python-brace-format
msgid "      – vanished during upload (deleted meanwhile), skipped: {p}"
msgstr "      – disparu pendant l'upload (supprimé entre-temps), ignoré : {p}"

#: proton_sync.py:941
#, python-brace-format
msgid "      ⚠ thumbnail/codec issue — retrying without thumbnail: {p}"
msgstr "      ⚠ souci de vignette/codec — ré-essai sans vignette : {p}"

#: proton_sync.py:945
#, python-brace-format
msgid "      ✓ uploaded WITHOUT thumbnail (no Proton preview): {p}"
msgstr "      ✓ téléversé SANS vignette (pas d'aperçu Proton) : {p}"

#: proton_sync.py:954
#, python-brace-format
msgid "      ✓ recovered on individual retry: {p}"
msgstr "      ✓ récupéré au ré-essai individuel : {p}"

#: proton_sync.py:957
#, python-brace-format
msgid "    ❌ upload failed: {p}"
msgstr "    ❌ échec d'upload : {p}"

#: proton_sync.py:958
#, python-brace-format
msgid "    ❌   reason: {e}"
msgstr "    ❌   raison : {e}"

#: proton_sync.py:958

msgid ""
"    ⛔ No write permission on {p} — ask the owner for access; skipping. ({e})"
msgstr ""
"    ⛔ Sem permissão de escrita em {p} — peça acesso ao proprietário; "
"ignorado. ({e})"

#, python-brace-format
msgid "    ⚠  Could not create {p}: {e}"
msgstr "    ⚠  Não foi possível criar {p}: {e}"

#, python-brace-format
msgid "    (nothing found at {p}: {e})"
msgstr "    (nada encontrado em {p}: {e})"


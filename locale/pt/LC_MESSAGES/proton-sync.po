#: config.py:314
msgid "The suffix cannot be empty."
msgstr "O sufixo não pode estar vazio."

#: config.py:316
msgid "The suffix cannot contain / \\ \" '."
msgstr "O sufixo não pode conter / \\ \" '."

#: config.py:399
#, python-brace-format
msgid "[config] Data folder migrated: {old} -> {new}"
msgstr "[config] Pasta de dados migrada: {old} -> {new}"

#: config.py:404
#, python-brace-format
msgid ""
"[config] ⚠ Could not migrate the data folder ({e}) — using the legacy paths "
"for this run."
msgstr ""
"[config] ⚠ Não foi possível migrar a pasta de dados ({e}) — a usar os "
"caminhos antigos para esta execução."

#: config.py:413
#, python-brace-format
msgid "[config] ⚠ Could not migrate the cache folder ({e})."
msgstr "[config] ⚠ Não foi possível migrar a pasta da cache ({e})."

#: proton_sync.py:208
#, python-brace-format
msgid "    ✎ [DRY-RUN] would fix uppercase extension: {a} -> {b}"
msgstr "    ✎ [DRY-RUN] corrigiria a extensão em maiúsculas: {a} -> {b}"

#: proton_sync.py:217
#, python-brace-format
msgid "    ✎ fixed uppercase extension: {a} -> {b}"
msgstr "    ✎ extensão em maiúsculas corrigida: {a} -> {b}"

#: proton_sync.py:221
#, python-brace-format
msgid "    ⚠  Could not rename {a}: {e}"
msgstr "    ⚠  Não foi possível renomear {a}: {e}"

#: proton_sync.py:278
#, python-brace-format
msgid "⚠  Cache corrupted or unreadable ({e}) — starting fresh."
msgstr "⚠  Cache danificada ou ilegível ({e}) — a recomeçar do zero."

#: proton_sync.py:720
#, python-brace-format
msgid "    ⚠  Could not create {p}: {e}"
msgstr "    ⚠  Não foi possível criar {p}: {e}"

#: proton_sync.py:731
#, python-brace-format
msgid "    (nothing found at {p}: {e})"
msgstr "    (nada encontrado em {p}: {e})"

#: proton_sync.py:738
msgid "    [debug] first raw element received from 'filesystem list -j':"
msgstr ""
"    [debug] primeiro elemento em bruto recebido de 'filesystem list -j':"

#: proton_sync.py:773
#, python-brace-format
msgid "    (remote size unknown for {f}, re-sending to be safe)"
msgstr "    (tamanho remoto desconhecido para {f}, a reenviar por segurança)"

#: proton_sync.py:781
#, python-brace-format
msgid "    (same size but different content: {f})"
msgstr "    (mesmo tamanho mas conteúdo diferente: {f})"

#: proton_sync.py:876
#, python-brace-format
msgid "    [DRY-RUN] would upload: {p}"
msgstr "    [DRY-RUN] carregaria: {p}"

#: proton_sync.py:898
#, python-brace-format
msgid "    ✅ {n} file(s) sent to {p}"
msgstr "    ✅ {n} ficheiro(s) enviado(s) para {p}"

#: proton_sync.py:904
#, python-brace-format
msgid ""
"    ⚠  Batch upload to {p} reported a failure — isolating the culprit "
"file(s)…"
msgstr ""
"    ⚠  O carregamento em lote para {p} reportou uma falha — a isolar o(s) "
"ficheiro(s) culpado(s)…"

#: proton_sync.py:923
#, python-brace-format
msgid "      – vanished before upload (deleted meanwhile), skipped: {p}"
msgstr ""
"      – desaparecido antes do carregamento (eliminado entretanto), saltado: "
"{p}"

#: proton_sync.py:934
#, python-brace-format
msgid "      – vanished during upload (deleted meanwhile), skipped: {p}"
msgstr ""
"      – desaparecido durante o carregamento (eliminado entretanto), saltado: "
"{p}"

#: proton_sync.py:941
#, python-brace-format
msgid "      ⚠ thumbnail/codec issue — retrying without thumbnail: {p}"
msgstr ""
"      ⚠ problema de miniatura/codec — a tentar novamente sem miniatura: {p}"

#: proton_sync.py:945
#, python-brace-format
msgid "      ✓ uploaded WITHOUT thumbnail (no Proton preview): {p}"
msgstr "      ✓ carregado SEM miniatura (sem pré-visualização do Proton): {p}"

#: proton_sync.py:954
#, python-brace-format
msgid "      ✓ recovered on individual retry: {p}"
msgstr "      ✓ recuperado em nova tentativa individual: {p}"

#: proton_sync.py:957
#, python-brace-format
msgid "    ❌ upload failed: {p}"
msgstr "    ❌ carregamento falhou: {p}"

#: proton_sync.py:958
#, python-brace-format
msgid "    ❌   reason: {e}"
msgstr "    ❌   motivo: {e}"

#: proton_sync.py:958
msgid "(no message from the CLI)"
msgstr "(sem mensagem da CLI)"

#: proton_sync.py:962
#, python-brace-format
msgid "    ✅ {n} file(s) recovered on individual retry."
msgstr "    ✅ {n} ficheiro(s) recuperado(s) em nova tentativa individual."

#: proton_sync.py:964
#, python-brace-format
msgid ""
"    ⚠  {n} file(s) uploaded WITHOUT thumbnail (image format needs an OS "
"codec — saved anyway, logged in {log})."
msgstr ""
"    ⚠  {n} ficheiro(s) carregado(s) SEM miniatura (o formato de imagem "
"precisa de um codec do SO — guardado mesmo assim, registado em {log})."

#: proton_sync.py:967
#, python-brace-format
msgid ""
"    – {n} file(s) vanished (deleted meanwhile) — skipped, not a failure."
msgstr ""
"    – {n} ficheiro(s) desaparecido(s) (eliminado(s) entretanto) — "
"saltado(s), não é uma falha."

#: proton_sync.py:969
#, python-brace-format
msgid "    ❌ {n} file(s) still failing (see the failures log: {log})."
msgstr ""
"    ❌ {n} ficheiro(s) continuam a falhar (consulte o registo de falhas: "
"{log})."

#: proton_sync.py:982
msgid "would delete PERMANENTLY"
msgstr "eliminaria PERMANENTEMENTE"

#: proton_sync.py:982
msgid "would move to trash"
msgstr "moveria para a reciclagem"

#: proton_sync.py:987
#, python-brace-format
msgid "    ❌ {a} of {p} failed: {e}"
msgstr "    ❌ {a} de {p} falhou: {e}"

#: proton_sync.py:989
msgid "permanently deleted"
msgstr "eliminado permanentemente"

#: proton_sync.py:989
msgid "sent to trash"
msgstr "enviado para a reciclagem"

#: proton_sync.py:1027
#, python-brace-format
msgid "    (orphan folder: {n} — ~{c} remote element(s))"
msgstr "    (pasta órfã: {n} — ~{c} elemento(s) remoto(s))"

#: proton_sync.py:1059
#, python-brace-format
msgid "  ⛔ Remote wipe REFUSED (mount guard): {r}"
msgstr "  ⛔ Apagamento remoto RECUSADO (proteção de montagem): {r}"

#: proton_sync.py:1060
msgid "     Nothing deleted remotely — this mapping was NOT reset."
msgstr "     Nada eliminado remotamente — este mapeamento NÃO foi reposto."

#: proton_sync.py:1065
#, python-brace-format
msgid "  ♻ No remote folder to wipe (already absent): {p}"
msgstr "  ♻ Nenhuma pasta remota para apagar (já ausente): {p}"

#: proton_sync.py:1067
#, python-brace-format
msgid "  🗑  Wiping remote folder to TRASH: {p}"
msgstr "  🗑  A apagar a pasta remota para a RECICLAGEM: {p}"

#: proton_sync.py:1097 proton_sync.py:1114
#, python-brace-format
msgid "  ❌ Could not read {p}: {e}"
msgstr "  ❌ Não foi possível ler {p}: {e}"

#: proton_sync.py:1175
#, python-brace-format
msgid "  ⚡ {t}, skipping the CLI call for {p}"
msgstr "  ⚡ {t}, a saltar a chamada à CLI para {p}"

#: proton_sync.py:1181
#, python-brace-format
msgid "  🚫 excluded (folder): {p}"
msgstr "  🚫 excluído (pasta): {p}"

#: proton_sync.py:1214
#, python-brace-format
msgid "    🚫 excluded ({k}): {p}"
msgstr "    🚫 excluído ({k}): {p}"

#: proton_sync.py:1230 proton_sync.py:1318
#, python-brace-format
msgid "    ⏭  unchanged: {p}"
msgstr "    ⏭  inalterado: {p}"

#: proton_sync.py:1289
#, python-brace-format
msgid "  ⚠  Deletions disabled for this mapping: {r}"
msgstr "  ⚠  Eliminações desativadas para este mapeamento: {r}"

#: proton_sync.py:1290 proton_sync.py:1477
msgid "      (uploads continue normally)"
msgstr "      (os carregamentos continuam normalmente)"

#: proton_sync.py:1293 proton_sync.py:1480
msgid "permanent"
msgstr "permanente"

#: proton_sync.py:1293 proton_sync.py:1480
msgid "to trash"
msgstr "para a reciclagem"

#: proton_sync.py:1294
#, python-brace-format
msgid "  🗑  Deletion propagation ACTIVE ({l}) for this mapping"
msgstr "  🗑  Propagação de eliminações ATIVA ({l}) para este mapeamento"

#: proton_sync.py:1309
#, python-brace-format
msgid "    🚫 excluded (file): {p}"
msgstr "    🚫 excluído (ficheiro): {p}"

#: proton_sync.py:1420
#, python-brace-format
msgid "  ❌ Subpath not found or not a folder: {p}"
msgstr "  ❌ Subcaminho não encontrado ou não é uma pasta: {p}"

#: proton_sync.py:1433
#, python-brace-format
msgid "subpath excluded (“{s}” filtered), skipped: {p}"
msgstr "subcaminho excluído («{s}» filtrado), saltado: {p}"

#: proton_sync.py:1455
#, python-brace-format
msgid ""
"folder not fully indexed yet (cache not built by a full pass), deferred to "
"scheduling: {p}"
msgstr ""
"pasta ainda não totalmente indexada (cache não construída por uma passagem "
"completa), adiada para o agendamento: {p}"

#: proton_sync.py:1476
#, python-brace-format
msgid "  ⚠  Deletions disabled for this subpath: {r}"
msgstr "  ⚠  Eliminações desativadas para este subcaminho: {r}"

#: proton_sync.py:1481
#, python-brace-format
msgid "  🗑  Deletion propagation ACTIVE ({l}) for this subpath"
msgstr "  🗑  Propagação de eliminações ATIVA ({l}) para este subcaminho"

#: proton_sync.py:1483
#, python-brace-format
msgid "  ↪ subpath: {s}  =>  {d}"
msgstr "  ↪ subcaminho: {s}  =>  {d}"

#: proton_sync.py:1617
msgid "❌ --wipe-remote requires --reset-source."
msgstr "❌ --wipe-remote requer --reset-source."

#: proton_sync.py:1638 proton_sync.py:1678
#, python-brace-format
msgid "❌ proton-drive binary not found at {p}"
msgstr "❌ binário proton-drive não encontrado em {p}"

#: proton_sync.py:1660
msgid "❌ A mappings file is required (config)."
msgstr "❌ É necessário um ficheiro de mapeamentos (configuração)."

#: proton_sync.py:1672
msgid "❌ Another instance of proton_sync.py is already running."
msgstr "❌ Já está a ser executada outra instância de proton_sync.py."

#: proton_sync.py:1673
#, python-brace-format
msgid "   Lock: {p}"
msgstr "   Bloqueio: {p}"

#: proton_sync.py:1674
msgid "   (If you are sure no other instance is running, delete this file.)"
msgstr ""
"   (Se tem a certeza de que nenhuma outra instância está em execução, "
"elimine este ficheiro.)"

#: proton_sync.py:1679
msgid "   Adjust the PROTON_DRIVE_CLI environment variable if needed."
msgstr "   Ajuste a variável de ambiente PROTON_DRIVE_CLI se necessário."

#: proton_sync.py:1693
msgid "Proton Drive authentication impossible — pass skipped."
msgstr "Autenticação do Proton Drive impossível — passagem saltada."

#: proton_sync.py:1694
msgid "   Likely cause: the graphical session is not open, so the"
msgstr "   Causa provável: a sessão gráfica não está aberta, por isso o"

#: proton_sync.py:1695
msgid "   secrets keyring is locked and the CLI cannot read its"
msgstr ""
"   chaveiro de segredos está bloqueado e a CLI não consegue ler as suas"

#: proton_sync.py:1696
msgid "   credentials."
msgstr "   credenciais."

#: proton_sync.py:1698
#, python-brace-format
msgid "   CLI detail: {e}"
msgstr "   Detalhe da CLI: {e}"

#: proton_sync.py:1699
msgid "   (This is not a serious error: the next run will retry."
msgstr "   (Não é um erro grave: a próxima execução tentará novamente."

#: proton_sync.py:1700
msgid "    Open this user's session to unlock the keyring.)"
msgstr "    Abra a sessão deste utilizador para desbloquear o chaveiro.)"

#: proton_sync.py:1730
#, python-brace-format
msgid ""
"Account change accepted ({a} → {b}) — the previous cache is discarded and "
"will be rebuilt for the new account."
msgstr ""
"Alteração de conta aceite ({a} → {b}) — a cache anterior é descartada e será "
"reconstruída para a nova conta."

#: proton_sync.py:1737
#, python-brace-format
msgid ""
"The connected Proton account has changed: this cache was built for {a}, but "
"the session is now {b}."
msgstr ""
"A conta Proton ligada mudou: esta cache foi criada para {a}, mas a sessão é "
"agora {b}."

#: proton_sync.py:1740
msgid ""
"   Nothing was synced or modified — the cache describes the OLD account's "
"Drive."
msgstr ""
"   Nada foi sincronizado ou modificado — a cache descreve o Drive da conta "
"ANTIGA."

#: proton_sync.py:1742
msgid ""
"   To proceed on the NEW account: run “Prime the cache” (or reset the "
"mappings). The destinations will be (re)created on the new Drive."
msgstr ""
"   Para prosseguir na NOVA conta: execute «Inicializar cache» (ou reponha os "
"mapeamentos). Os destinos serão (re)criados no novo Drive."

#: proton_sync.py:1768
msgid ""
"⏹ Interrupted — cache progress saved: resuming will skip what is already "
"done (no restart from zero)."
msgstr ""
"⏹ Interrompido — progresso da cache guardado: ao retomar, o que já está "
"feito será saltado (sem reinício do zero)."

#: proton_sync.py:1777
msgid "DRY-RUN (nothing will be transferred)"
msgstr "DRY-RUN (nada será transferido)"

#: proton_sync.py:1777
msgid "real"
msgstr "real"

#: proton_sync.py:1786
#, python-brace-format
msgid "== Proton Drive sync — {n} entry(ies) — {m}{x} =="
msgstr "== Sincronização do Proton Drive — {n} entrada(s) — {m}{x} =="

#: proton_sync.py:1788
#, python-brace-format
msgid "   Cache: {p} ({n} known folder(s))"
msgstr "   Cache: {p} ({n} pasta(s) conhecida(s))"

#: proton_sync.py:1795
msgid ""
"   ↺ Resuming on an existing cache — work already recorded won't be redone "
"(unchanged folders are skipped)."
msgstr ""
"   ↺ A retomar numa cache existente — o trabalho já registado não será "
"refeito (as pastas inalteradas são saltadas)."

#: proton_sync.py:1800
#, python-brace-format
msgid "   Global exclusions: {n} name(s), {p} pattern(s)"
msgstr "   Exclusões globais: {n} nome(s), {p} padrão(ões)"

#: proton_sync.py:1814
#, python-brace-format
msgid "   ⟳ Restricted to {n} selected mapping(s) (of {t})."
msgstr "   ⟳ Restrito a {n} mapeamento(s) selecionado(s) (de {t})."

#: proton_sync.py:1827
#, python-brace-format
msgid "   ⚠  DELETION mode active — {n} mapping(s) with allow_delete"
msgstr "   ⚠  Modo ELIMINAÇÃO ativo — {n} mapeamento(s) com allow_delete"

#: proton_sync.py:1828
#, python-brace-format
msgid ", including {n} PERMANENT"
msgstr ", incluindo {n} PERMANENTES"

#: proton_sync.py:1830
msgid ""
"   ⚠  mount_check.py missing: ALL deletions will be refused (safety guard)."
msgstr ""
"   ⚠  mount_check.py em falta: TODAS as eliminações serão recusadas "
"(proteção de segurança)."

#: proton_sync.py:1840
msgid "❌ --subpath requires --mapping-source to identify the mapping."
msgstr "❌ --subpath requer --mapping-source para identificar o mapeamento."

#: proton_sync.py:1849
#, python-brace-format
msgid "❌ No mapping with source = {s}"
msgstr "❌ Nenhum mapeamento com origem = {s}"

#: proton_sync.py:1852
#, python-brace-format
msgid "❌ --subpath only applies to 'folder' mappings (this one is '{t}')."
msgstr ""
"❌ --subpath só se aplica a mapeamentos do tipo 'folder' (este é '{t}')."

#: proton_sync.py:1856
#, python-brace-format
msgid "== REAL-TIME sync — subpath of a mapping — {m} =="
msgstr "== Sincronização em TEMPO REAL — subcaminho de um mapeamento — {m} =="

#: proton_sync.py:1857
#, python-brace-format
msgid "   Mapping: {s}  =>  {d}"
msgstr "   Mapeamento: {s}  =>  {d}"

#: proton_sync.py:1859
msgid "   ⚠  Deletion propagation requested (--delete)"
msgstr "   ⚠  Propagação de eliminações solicitada (--delete)"

#: proton_sync.py:1872 proton_sync.py:1939
msgid "Done."
msgstr "Concluído."

#: proton_sync.py:1886
#, python-brace-format
msgid "   ♻ RESET restricted to {n} selected mapping(s) (of {t})."
msgstr "   ♻ REPOSIÇÃO restrita a {n} mapeamento(s) selecionado(s) (de {t})."

#: proton_sync.py:1900
#, python-brace-format
msgid "   ♻ {n} cache entry(ies) purged: {s}"
msgstr "   ♻ {n} entrada(s) de cache eliminada(s): {s}"

#: proton_sync.py:1913
#, python-brace-format
msgid ""
"\n"
"▶ Mapping {i}/{n} : {s}  =>  {d}"
msgstr ""
"\n"
"▶ Mapeamento {i}/{n} : {s}  =>  {d}"

#: proton_sync.py:1915
#, python-brace-format
msgid "  ❌ Source not found, skipped: {s}"
msgstr "  ❌ Origem não encontrada, saltada: {s}"

#: realtime_consumer.py:238
#, python-brace-format
msgid "  🔎 self-test marker acknowledged (id {i})."
msgstr "  🔎 marcador de autoteste confirmado (id {i})."

#: realtime_consumer.py:241
#, python-brace-format
msgid "  ⚠ self-test reply write failed: {e}"
msgstr "  ⚠ falha ao escrever a resposta de autoteste: {e}"

#: realtime_consumer.py:461
#, python-brace-format
msgid "  ⊘ folder vanished, skipped: {p}"
msgstr "  ⊘ pasta desaparecida, saltada: {p}"

#: realtime_consumer.py:468
#, python-brace-format
msgid "  ⊘ no mapping for: {p} (marker ignored)"
msgstr "  ⊘ nenhum mapeamento para: {p} (marcador ignorado)"

#: realtime_consumer.py:473
msgid " [with deletions]"
msgstr " [com eliminações]"

#: realtime_consumer.py:474
#, python-brace-format
msgid "  → sync: {p}{f}"
msgstr "  → sincronização: {p}{f}"

#: realtime_consumer.py:489
msgid "    🚫 excluded (name filtered) — nothing to sync"
msgstr "    🚫 excluído (nome filtrado) — nada a sincronizar"

#: realtime_consumer.py:491
msgid "    ✓ ok"
msgstr "    ✓ ok"

#: realtime_consumer.py:506
msgid ""
"    ⏳ cold folder — deferred to the scheduled pass (real-time does not "
"build the cache)"
msgstr ""
"    ⏳ pasta fria — adiada para a passagem agendada (o tempo real não "
"constrói a cache)"

#: realtime_consumer.py:519
msgid ""
"    ⛔ account changed — engine refused (cache belongs to the previous "
"account); markers kept"
msgstr ""
"    ⛔ conta alterada — o motor recusou (a cache pertence à conta anterior); "
"marcadores mantidos"

#: realtime_consumer.py:526
#, python-brace-format
msgid "    ✗ failure (code {c}) — markers kept for retry"
msgstr "    ✗ falha (código {c}) — marcadores mantidos para nova tentativa"

#: realtime_consumer.py:762
#, python-brace-format
msgid "Real-time daemon started (user {u})."
msgstr "Serviço em tempo real iniciado (utilizador {u})."

#: realtime_consumer.py:763
#, python-brace-format
msgid "  Engine: {p}"
msgstr "  Motor: {p}"

#: realtime_consumer.py:771
#, python-brace-format
msgid ""
"  • {r}/{t} mapping(s) ready for real-time. The others need a full pass "
"(Schedule) before real-time can sync them."
msgstr ""
"  • {r}/{t} mapeamento(s) prontos para tempo real. Os restantes necessitam "
"de uma passagem completa (Agendamento) antes de o tempo real os poder "
"sincronizar."

#: realtime_consumer.py:774
#, python-brace-format
msgid "  • {r}/{t} mapping(s) ready for real-time."
msgstr "  • {r}/{t} mapeamento(s) prontos para tempo real."

#: realtime_consumer.py:821
msgid "▶ NAS back online — resuming NAS mappings."
msgstr "▶ NAS de volta — a retomar os mapeamentos NAS."

#: realtime_consumer.py:823
msgid ""
"⏸ NAS unreachable — NAS mappings suspended, local mode active. Local "
"mappings keep syncing."
msgstr ""
"⏸ NAS inacessível — mapeamentos NAS suspensos, modo local ativo. Os "
"mapeamentos locais continuam a sincronizar."

#: realtime_consumer.py:826
msgid "NAS disabled — local mode only."
msgstr "NAS desativado — apenas modo local."

#: realtime_consumer.py:853
msgid "🔓 Session opened — starting the pass."
msgstr "🔓 Sessão aberta — a iniciar a passagem."

#: realtime_consumer.py:855
msgid "🔓 Lock released — starting the pass."
msgstr "🔓 Bloqueio libertado — a iniciar a passagem."

#: realtime_consumer.py:857
msgid "🔓 Account matter resolved — starting the pass."
msgstr "🔓 Problema de conta resolvido — a iniciar a passagem."

#: realtime_consumer.py:875
msgid ""
"⏳ Proton authentication unavailable (expired session or locked keyring) — "
"markers kept, no pass launched. Run “proton-drive auth login” (or the “Sign "
"in to Proton” button) to renew the session."
msgstr ""
"⏳ Autenticação do Proton indisponível (sessão expirada ou chaveiro "
"bloqueado) — marcadores mantidos, nenhuma passagem iniciada. Execute «proton-"
"drive auth login» (ou o botão «Iniciar sessão no Proton») para renovar a "
"sessão."

#: realtime_consumer.py:880
msgid ""
"⛔ Proton account changed — the cache belongs to the previous account. "
"Markers kept; prime the cache (or reset the mappings) from the GUI to resume."
msgstr ""
"⛔ Conta Proton alterada — a cache pertence à conta anterior. Marcadores "
"mantidos; inicialize a cache (ou reponha os mapeamentos) a partir da "
"interface para retomar."

#: realtime_consumer.py:884
msgid ""
"⏳ Waiting: another pass holds the lock (manual or scheduled run) — markers "
"kept, no pass launched."
msgstr ""
"⏳ A aguardar: outra passagem detém o bloqueio (execução manual ou agendada) "
"— marcadores mantidos, nenhuma passagem iniciada."

#: realtime_consumer.py:892
msgid "✓ Pass finished."
msgstr "✓ Passagem concluída."

#: local_watcher.py:362
#, python-brace-format
msgid "  ⊘ DELETE ignored (NAS mount unhealthy): {p}"
msgstr "  ⊘ ELIMINAÇÃO ignorada (montagem NAS em mau estado): {p}"

#: local_watcher.py:368
#, python-brace-format
msgid "  {t} {p} -> marker on {d}"
msgstr "  {t} {p} -> marcador em {d}"

#: local_watcher.py:370
#, python-brace-format
msgid "  ⚠ marker write failed: {e}"
msgstr "  ⚠ escrita do marcador falhou: {e}"

#: local_watcher.py:405
#, python-brace-format
msgid "  ➕ target added: [{k}] {d}"
msgstr "  ➕ alvo adicionado: [{k}] {d}"

#: local_watcher.py:407
#, python-brace-format

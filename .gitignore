.proton-drive-sync/
# Anciens emplacements (avant unification), au cas où.
.proton_sync_cache/
.proton_sync/
.proton_sync.lock
# ─── Python ───────────────────────────────────────────────────────────────
__pycache__/
*.py[cod]
*.egg-info/
.venv/
venv/
# ─── Divers OS / éditeurs ─────────────────────────────────────────────────
.DS_Store
Thumbs.db
*.swp
*~
